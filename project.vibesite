{"site":{"pages":[{"name":"about.html","html":"<link rel=\"stylesheet\" href=\"style.css\">\n<div class=\"page-transition\"></div>\n<header id=\"main-header\">\n  <div class=\"container header-inner\">\n    <a href=\"index.html\" class=\"logo\">AMIEL NAVIGAR</a>\n    <nav>\n      <ul class=\"nav-links\">\n        <li><a href=\"index.html\">HOME</a></li>\n        <li><a href=\"work.html\">WORK</a></li>\n        <li><a href=\"about.html\" class=\"active\">ABOUT</a></li>\n        <li><a href=\"contact.html\">CONTACT</a></li>\n        <li>\n          <button id=\"theme-toggle\" class=\"theme-toggle\" aria-label=\"Toggle Theme\">\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"currentColor\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 2v20a10 10 0 1 0 0-20z\"/></svg>\n          </button>\n        </li>\n      </ul>\n    </nav>\n  </div>\n</header>\n\n<main class=\"page-about\">\n  <section class=\"about-hero fade-in-up\">\n    <div class=\"container split-layout\">\n      <div class=\"split-text\">\n        <div class=\"label\">[ABOUT]</div>\n        <h1 class=\"page-title\">The beauty<br>of <span class=\"accent-italic\">imperfection</span></h1>\n        <div class=\"bio-text mt-2 text-muted\">\n          <p>I'm a multimedia designer specializing in graphic design and video production. My work is deeply influenced by industrial and brutalist aesthetics — raw materials, exposed structures, and unpolished surfaces.</p>\n          <p>Equally important to my practice is the Japanese concept of wabi-sabi: the acceptance of transience and imperfection. I believe the most compelling design work comes from embracing what's incomplete, finding character in the worn, and creating meaning through restraint.</p>\n          <p>Every project is an opportunity to strip away the unnecessary and reveal something honest underneath.</p>\n        </div>\n      </div>\n      <div class=\"split-visuals\">\n         <div class=\"asset-box box-portrait\">\n             <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n             <div class=\"crosshair\"></div>\n             <div class=\"project-hover\">\n               <h3 class=\"project-title\">Self Portrait</h3>\n               <span class=\"project-year\">Photography 2024</span>\n            </div>\n         </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"experience fade-in-up mt-4\">\n    <div class=\"container\">\n      <div class=\"label\">[EXPERIENCE]</div>\n      <h2 class=\"section-title\">Background</h2>\n      \n      <div class=\"exp-list\">\n        <div class=\"exp-item exp-item-detailed\">\n          <div class=\"exp-header\">\n            <div class=\"exp-role\">Multimedia Designer <span class=\"text-muted\">— Xillium</span></div>\n            <div class=\"exp-date label\">2023 — Present</div>\n          </div>\n          <div class=\"exp-details text-muted text-sm mt-1\">\n            <p class=\"mb-1\"><em>Hybrid Setup</em></p>\n            <ul class=\"bullet-list\">\n              <li>Develop creative digital content for healthcare outsourcing clients, ensuring brand consistency across platforms.</li>\n              <li>Design marketing collaterals, social media graphics, and internal communication materials.</li>\n              <li>Collaborate with cross-functional teams to deliver effective design solutions within deadlines.</li>\n              <li>Produced professional layouts that strengthened visual branding.</li>\n            </ul>\n          </div>\n        </div>\n        <div class=\"exp-item exp-item-detailed\">\n          <div class=\"exp-header\">\n            <div class=\"exp-role\">Graphic Support Intern <span class=\"text-muted\">— ADA Asia</span></div>\n            <div class=\"exp-date label\">2023</div>\n          </div>\n          <div class=\"exp-details text-muted text-sm mt-1\">\n            <p class=\"mb-1\"><em>Office Based</em></p>\n            <ul class=\"bullet-list\">\n              <li>Created and delivered branded content for digital campaigns.</li>\n              <li>Handled the end-to-end development of creative projects from ideation to execution.</li>\n              <li>Designed online and offline collaterals for marketing initiatives.</li>\n              <li>Translated concepts and moods into impactful creative outputs.</li>\n            </ul>\n          </div>\n        </div>\n        <div class=\"exp-item exp-item-detailed\">\n          <div class=\"exp-header\">\n            <div class=\"exp-role\">Freelance Artist <span class=\"text-muted\">— Upwork</span></div>\n            <div class=\"exp-date label\">2022 — Present</div>\n          </div>\n          <div class=\"exp-details text-muted text-sm mt-1\">\n            <ul class=\"bullet-list\">\n              <li>Designed logos, brand identities, marketing collateral, illustrations, and more for international clients.</li>\n              <li>Specialized in visually captivating designs that communicate key messages effectively.</li>\n              <li>Maintained consistent collaboration with clients to ensure brand alignment.</li>\n            </ul>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"skills fade-in-up mt-4 mb-4\">\n    <div class=\"container\">\n      <div class=\"label\">[TOOLS & SKILLS]</div>\n      <h2 class=\"section-title\">Software & Qualifications</h2>\n      \n      <div class=\"tags-container mt-2\">\n        <span class=\"tag\">ADOBE CREATIVE SUITE</span>\n        <span class=\"tag\">PHOTOSHOP</span>\n        <span class=\"tag\">ILLUSTRATOR</span>\n        <span class=\"tag\">AFTER EFFECTS</span>\n        <span class=\"tag\">PREMIERE PRO</span>\n        <span class=\"tag\">AI-READY</span>\n        <span class=\"tag\">TEAM COLLABORATION</span>\n        <span class=\"tag\">INDEPENDENT WORK</span>\n        <span class=\"tag\">DETAIL-ORIENTED</span>\n        <span class=\"tag\">COMMUNICATION</span>\n      </div>\n\n      <div class=\"grid-3 mt-4\">\n        <div class=\"info-card\">\n          <h3 class=\"card-title\">Wabi-Sabi</h3>\n          <p class=\"text-muted text-sm\">Finding beauty in imperfection, impermanence, and incompleteness. Every crack tells a story.</p>\n        </div>\n        <div class=\"info-card\">\n          <h3 class=\"card-title\">Brutalism</h3>\n          <p class=\"text-muted text-sm\">Honesty in materials. Raw, unadorned, functional. Structure exposed, intention clear.</p>\n        </div>\n        <div class=\"info-card\">\n          <h3 class=\"card-title\">Industrial</h3>\n          <p class=\"text-muted text-sm\">The poetry of production. Machinery, texture, repetition. Where function becomes form.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n</main>\n\n<footer class=\"site-footer\">\n  <div class=\"container\">\n    <div class=\"footer-grid\">\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">MULTIMEDIA DESIGNER</h4>\n        <p class=\"text-muted\">Embracing imperfection.<br>Finding beauty in the raw.</p>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">NAVIGATION</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"index.html\">Home</a></li>\n          <li><a href=\"work.html\">Work</a></li>\n          <li><a href=\"about.html\">About</a></li>\n          <li><a href=\"contact.html\">Contact</a></li>\n        </ul>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">CONNECT</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"https://www.linkedin.com/in/amielnavigar/\" target=\"_blank\" rel=\"noopener noreferrer\">LinkedIn</a></li>\n        </ul>\n      </div>\n    </div>\n    <div class=\"footer-bottom\">\n      <div class=\"copyright\">© 2026</div>\n      <div class=\"quote\">Nothing is permanent.</div>\n    </div>\n  </div>\n</footer>\n\n<div id=\"custom-cursor\" class=\"custom-cursor\"></div>\n<script src=\"script.js\"></script>"},{"name":"contact.html","html":"<link rel=\"stylesheet\" href=\"style.css\">\n<div class=\"page-transition\"></div>\n<header id=\"main-header\">\n  <div class=\"container header-inner\">\n    <a href=\"index.html\" class=\"logo\">AMIEL NAVIGAR</a>\n    <nav>\n      <ul class=\"nav-links\">\n        <li><a href=\"index.html\">HOME</a></li>\n        <li><a href=\"work.html\">WORK</a></li>\n        <li><a href=\"about.html\">ABOUT</a></li>\n        <li><a href=\"contact.html\" class=\"active\">CONTACT</a></li>\n        <li>\n          <button id=\"theme-toggle\" class=\"theme-toggle\" aria-label=\"Toggle Theme\">\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"currentColor\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 2v20a10 10 0 1 0 0-20z\"/></svg>\n          </button>\n        </li>\n      </ul>\n    </nav>\n  </div>\n</header>\n\n<main class=\"page-contact\">\n  <section class=\"contact-section fade-in-up\">\n    <div class=\"container split-layout-contact\">\n      <div class=\"contact-info\">\n        <div class=\"label\">[CONTACT]</div>\n        <h1 class=\"page-title\">Let's build<br>something <span class=\"accent-italic\">raw.</span></h1>\n        <p class=\"mt-2 text-muted max-w-sm\">\n          Open for freelance projects, collaborations, and creative partnerships. Let's create work that embraces imperfection.\n        </p>\n\n        <div class=\"contact-details mt-3\">\n          <div class=\"contact-item\">\n            <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--accent-color)\" stroke-width=\"1.5\"><rect x=\"2\" y=\"4\" width=\"20\" height=\"16\" rx=\"2\"/><path d=\"m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7\"/></svg>\n            <span class=\"label mono-text\">amielnavigar@gmail.com</span>\n          </div>\n          <div class=\"contact-item mt-1\">\n            <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--accent-color)\" stroke-width=\"1.5\"><path d=\"M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z\"/><circle cx=\"12\" cy=\"10\" r=\"3\"/></svg>\n            <span class=\"label mono-text\">Iloilo, Philippines</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"contact-form-wrapper\">\n        <form class=\"contact-form\">\n          <div class=\"form-group\">\n            <label class=\"label\" for=\"name\">NAME</label>\n            <input type=\"text\" id=\"name\" placeholder=\"Your name\" required>\n          </div>\n          <div class=\"form-group\">\n            <label class=\"label\" for=\"email\">EMAIL</label>\n            <input type=\"email\" id=\"email\" placeholder=\"your@email.com\" required>\n          </div>\n          <div class=\"form-group\">\n            <label class=\"label\" for=\"type\">PROJECT TYPE</label>\n            <input type=\"text\" id=\"type\" placeholder=\"Graphic / Video / Motion / Other\">\n          </div>\n          <div class=\"form-group\">\n            <label class=\"label\" for=\"message\">MESSAGE</label>\n            <textarea id=\"message\" rows=\"4\" placeholder=\"Tell me about your project...\" required></textarea>\n          </div>\n          <button type=\"submit\" class=\"btn-outline mt-2\">SEND MESSAGE <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M5 12h14M12 5l7 7-7\"/></svg></button>\n        </form>\n      </div>\n    </div>\n  </section>\n</main>\n\n<footer class=\"site-footer\">\n  <div class=\"container\">\n    <div class=\"footer-grid\">\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">MULTIMEDIA DESIGNER</h4>\n        <p class=\"text-muted\">Embracing imperfection.<br>Finding beauty in the raw.</p>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">NAVIGATION</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"index.html\">Home</a></li>\n          <li><a href=\"work.html\">Work</a></li>\n          <li><a href=\"about.html\">About</a></li>\n          <li><a href=\"contact.html\">Contact</a></li>\n        </ul>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">CONNECT</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"https://www.linkedin.com/in/amielnavigar/\" target=\"_blank\" rel=\"noopener noreferrer\">LinkedIn</a></li>\n        </ul>\n      </div>\n    </div>\n    <div class=\"footer-bottom\">\n      <div class=\"copyright\">© 2026</div>\n      <div class=\"quote\">Nothing is permanent.</div>\n    </div>\n  </div>\n</footer>\n\n<div id=\"custom-cursor\" class=\"custom-cursor\"></div>\n<script src=\"script.js\"></script>"},{"name":"index.html","html":"<link rel=\"stylesheet\" href=\"style.css\">\n<div class=\"page-transition\"></div>\n<header id=\"main-header\">\n  <div class=\"container header-inner\">\n    <a href=\"index.html\" class=\"logo\">AMIEL NAVIGAR</a>\n    <nav>\n      <ul class=\"nav-links\">\n        <li><a href=\"index.html\" class=\"active\">HOME</a></li>\n        <li><a href=\"work.html\">WORK</a></li>\n        <li><a href=\"about.html\">ABOUT</a></li>\n        <li><a href=\"contact.html\">CONTACT</a></li>\n        <li>\n          <button id=\"theme-toggle\" class=\"theme-toggle\" aria-label=\"Toggle Theme\">\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"currentColor\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 2v20a10 10 0 1 0 0-20z\"/></svg>\n          </button>\n        </li>\n      </ul>\n    </nav>\n  </div>\n</header>\n\n<main>\n  <section class=\"hero fade-in-up\">\n    <div class=\"container\">\n      <div class=\"label\">[MULTIMEDIA DESIGNER]</div>\n      <h1 class=\"hero-title\">Crafting<br>the <span class=\"accent-italic\">Imperfect</span></h1>\n      <div class=\"hero-sub\">\n        <p>Graphic design & video work rooted in brutalist aesthetics and wabi-sabi philosophy. Embracing rawness, impermanence, and the beauty of what's unfinished.</p>\n        <a href=\"work.html\" class=\"link-btn\">VIEW WORK <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M5 12h14M12 5l7 7-7\"/></svg></a>\n      </div>\n    </div>\n  </section>\n\n  <div class=\"marquee\">\n    <div class=\"marquee-content\">\n      <span class=\"marquee-text\">NOTHING IS PERMANENT • CRAFTING THE IMPERFECT • </span>\n      <span class=\"marquee-text\">EMBRACING RAWNESS • FINDING BEAUTY IN SIMPLICITY • </span>\n      <span class=\"marquee-text\">NOTHING IS PERMANENT • CRAFTING THE IMPERFECT • </span>\n      <span class=\"marquee-text\">EMBRACING RAWNESS • FINDING BEAUTY IN SIMPLICITY • </span>\n    </div>\n  </div>\n\n  <section class=\"recent-projects fade-in-up\">\n    <div class=\"container\">\n      <div class=\"label\">[SELECTED WORK]</div>\n      <h2 class=\"section-title\">Recent Projects</h2>\n      \n      <div class=\"bento-grid\">\n        <a href=\"project-becker.html\" class=\"asset-box span-3\" data-category=\"graphic\">\n           <img src=\"asset://1774738706550\" alt=\"Becker's Event Announcement\" class=\"asset-media\" referrerPolicy=\"no-referrer\">\n           <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n           <div class=\"crosshair\"></div>\n           <div class=\"project-hover\">\n             <h3 class=\"project-title\">Becker's Event</h3>\n             <span class=\"project-year\">Graphic 2026</span>\n          </div>\n        </a>\n        <a href=\"project-mgma.html\" class=\"asset-box span-3\" data-category=\"video\">\n          <video autoplay loop muted playsinline class=\"asset-media\">\n            <source src=\"asset://1774738684886\" type=\"video/mp4\">\n          </video>\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"crosshair\"></div>\n          <div class=\"project-hover\">\n             <h3 class=\"project-title\">MGMA Wrap Up Video</h3>\n             <span class=\"project-year\">Video 2025</span>\n          </div>\n        </a>\n        <a href=\"project-veega.html\" class=\"asset-box span-3\" data-category=\"animation\">\n           <video autoplay loop muted playsinline class=\"asset-media\">\n             <source src=\"asset://1774738660376\" type=\"video/mp4\">\n           </video>\n           <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n           <div class=\"crosshair\"></div>\n           <div class=\"project-hover\">\n             <h3 class=\"project-title\">Veega Instagram Ad</h3>\n             <span class=\"project-year\">Animation 2023</span>\n          </div>\n        </a>\n        <a href=\"project-samsung.html\" class=\"asset-box span-3\" data-category=\"graphic\">\n           <img src=\"asset://o6s4kgm2s\" alt=\"Samsung Product Ad\" class=\"asset-media\" referrerPolicy=\"no-referrer\">\n           <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n           <div class=\"crosshair\"></div>\n           <div class=\"project-hover\">\n             <h3 class=\"project-title\">Samsung Product Ad</h3>\n             <span class=\"project-year\">Graphic 2023</span>\n          </div>\n        </a>\n      </div>\n      <div class=\"align-right mt-2\">\n         <a href=\"work.html\" class=\"link-btn\">ALL PROJECTS <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M5 12h14M12 5l7 7-7\"/></svg></a>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"philosophy fade-in-up\">\n    <div class=\"container split-layout align-center\">\n      <div class=\"split-text\">\n        <div class=\"label\">[PHILOSOPHY]</div>\n        <h2 class=\"large-heading\">Nothing lasts, nothing is finished, nothing is <span class=\"accent-italic\">perfect.</span></h2>\n        <p class=\"mt-1 text-muted\">My work lives at the intersection of industrial design thinking and the Japanese aesthetic of wabi-sabi — finding depth in simplicity, character in wear, and meaning in transience.</p>\n      </div>\n      <div class=\"split-visuals\">\n         <a href=\"about.html\" class=\"asset-box box-tall\">\n             <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n             <div class=\"crosshair\"></div>\n             <div class=\"project-hover\">\n               <h3 class=\"project-title\">Studio Process</h3>\n               <span class=\"project-year\">Behind the scenes</span>\n            </div>\n         </a>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"capabilities fade-in-up\">\n    <div class=\"container\">\n       <div class=\"label\">[CAPABILITIES]</div>\n       <h2 class=\"section-title\">What I Do</h2>\n       <div class=\"grid-4\">\n         <div class=\"capability-item\">\n           <div class=\"cap-num label\">01</div>\n           <h3 class=\"cap-title\">Graphic Design</h3>\n           <p class=\"text-muted\">Brand identities, posters, editorial, packaging</p>\n         </div>\n         <div class=\"capability-item\">\n           <div class=\"cap-num label\">02</div>\n           <h3 class=\"cap-title\">Motion Design</h3>\n           <p class=\"text-muted\">Animations, title sequences, motion graphics</p>\n         </div>\n         <div class=\"capability-item\">\n           <div class=\"cap-num label\">03</div>\n           <h3 class=\"cap-title\">Video Production</h3>\n           <p class=\"text-muted\">Short films, campaigns, visual essays</p>\n         </div>\n         <div class=\"capability-item\">\n           <div class=\"cap-num label\">04</div>\n           <h3 class=\"cap-title\">Art Direction</h3>\n           <p class=\"text-muted\">Visual strategy, creative direction, concepts</p>\n         </div>\n       </div>\n    </div>\n  </section>\n\n  <section class=\"cta-section fade-in-up\">\n    <div class=\"container text-center\">\n      <div class=\"label\">[LET'S COLLABORATE]</div>\n      <h2 class=\"mega-title\">Have a project<br>in mind?</h2>\n      <a href=\"contact.html\" class=\"btn-outline mt-2\">GET IN TOUCH <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M5 12h14M12 5l7 7-7\"/></svg></a>\n    </div>\n  </section>\n</main>\n\n<footer class=\"site-footer\">\n  <div class=\"container\">\n    <div class=\"footer-grid\">\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">MULTIMEDIA DESIGNER</h4>\n        <p class=\"text-muted\">Embracing imperfection.<br>Finding beauty in the raw.</p>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">NAVIGATION</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"index.html\">Home</a></li>\n          <li><a href=\"work.html\">Work</a></li>\n          <li><a href=\"about.html\">About</a></li>\n          <li><a href=\"contact.html\">Contact</a></li>\n        </ul>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">CONNECT</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"https://www.linkedin.com/in/amielnavigar/\" target=\"_blank\" rel=\"noopener noreferrer\">LinkedIn</a></li>\n        </ul>\n      </div>\n    </div>\n    <div class=\"footer-bottom\">\n      <div class=\"copyright\">© 2026</div>\n      <div class=\"quote\">Nothing is permanent.</div>\n    </div>\n  </div>\n</footer>\n\n<div id=\"custom-cursor\" class=\"custom-cursor\"></div>\n<script src=\"script.js\"></script>"},{"name":"work.html","html":"<link rel=\"stylesheet\" href=\"style.css\">\n<div class=\"page-transition\"></div>\n<header id=\"main-header\">\n  <div class=\"container header-inner\">\n    <a href=\"index.html\" class=\"logo\">AMIEL NAVIGAR</a>\n    <nav>\n      <ul class=\"nav-links\">\n        <li><a href=\"index.html\">HOME</a></li>\n        <li><a href=\"work.html\" class=\"active\">WORK</a></li>\n        <li><a href=\"about.html\">ABOUT</a></li>\n        <li><a href=\"contact.html\">CONTACT</a></li>\n        <li>\n          <button id=\"theme-toggle\" class=\"theme-toggle\" aria-label=\"Toggle Theme\">\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"currentColor\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 2v20a10 10 0 1 0 0-20z\"/></svg>\n          </button>\n        </li>\n      </ul>\n    </nav>\n  </div>\n</header>\n\n<main class=\"page-work\">\n  <section class=\"work-header fade-in-up\">\n    <div class=\"container\">\n      <div class=\"label\">[PORTFOLIO]</div>\n      <h1 class=\"page-title\">Selected Work</h1>\n      \n      <div class=\"filter-bar mt-3\">\n        <button class=\"filter-btn active\" data-filter=\"all\">ALL (25)</button>\n        <button class=\"filter-btn\" data-filter=\"graphic\">GRAPHIC (15)</button>\n        <button class=\"filter-btn\" data-filter=\"video\">VIDEO (3)</button>\n        <button class=\"filter-btn\" data-filter=\"animation\">ANIMATION (7)</button>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"work-gallery fade-in-up\">\n    <div class=\"container\">\n      <div class=\"gallery-grid\">\n        \n        <a href=\"project-becker.html\" class=\"asset-box\" data-category=\"graphic\">\n          <img src=\"asset://1774738706550\" alt=\"Becker's Event Announcement\" class=\"asset-media\" referrerPolicy=\"no-referrer\">\n          <div class=\"corner corner-tl\"></div><div c