=\"container text-center\">\n      <p class=\"label\">[CONTINUE]</p>\n      <a href=\"project-becker.html\" class=\"mega-title hover-accent\">Next Project <svg width=\"40\" height=\"40\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1\"><path d=\"M5 12h14M12 5l7 7-7\"/></svg></a>\n    </div>\n  </section>\n</main>\n\n<footer class=\"site-footer\">\n  <div class=\"container\">\n    <div class=\"footer-grid\">\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">MULTIMEDIA DESIGNER</h4>\n        <p class=\"text-muted\">Embracing imperfection.<br>Finding beauty in the raw.</p>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">NAVIGATION</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"index.html\">Home</a></li>\n          <li><a href=\"work.html\">Work</a></li>\n          <li><a href=\"about.html\">About</a></li>\n          <li><a href=\"contact.html\">Contact</a></li>\n        </ul>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">CONNECT</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"https://www.linkedin.com/in/amielnavigar/\" target=\"_blank\" rel=\"noopener noreferrer\">LinkedIn</a></li>\n        </ul>\n      </div>\n    </div>\n    <div class=\"footer-bottom\">\n      <div class=\"copyright\">© 2026</div>\n      <div class=\"quote\">Nothing is permanent.</div>\n    </div>\n  </div>\n</footer>\n\n<div id=\"custom-cursor\" class=\"custom-cursor\"></div>\n<script src=\"script.js\"></script>"},{"name":"project-2026-coffee.html","html":"<title>2026 Coffee Design - Amiel Navigar | Multimedia Designer</title>\n<link rel=\"stylesheet\" href=\"style.css\">\n<div class=\"page-transition\"></div>\n<header id=\"main-header\">\n  <div class=\"container header-inner\">\n    <a href=\"index.html\" class=\"logo\">AMIEL NAVIGAR</a>\n    <nav>\n      <ul class=\"nav-links\">\n        <li><a href=\"index.html\">HOME</a></li>\n        <li><a href=\"work.html\" class=\"active\">WORK</a></li>\n        <li><a href=\"about.html\">ABOUT</a></li>\n        <li><a href=\"contact.html\">CONTACT</a></li>\n        <li>\n          <button id=\"theme-toggle\" class=\"theme-toggle\" aria-label=\"Toggle Theme\">\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"currentColor\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 2v20a10 10 0 1 0 0-20z\"/></svg>\n          </button>\n        </li>\n      </ul>\n    </nav>\n  </div>\n</header>\n\n<main class=\"page-project\">\n  <section class=\"project-hero fade-in-up\">\n    <div class=\"container\">\n      <a href=\"work.html\" class=\"link-btn mb-4\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M19 12H5M12 19l-7-7 7-7\"/></svg> BACK TO WORK</a>\n      \n      <div class=\"label\">[CASE STUDY]</div>\n      <h1 class=\"mega-title\">2026 Coffee<br>Design</h1>\n      \n      <div class=\"project-meta mt-3\">\n        <div class=\"meta-item\">\n          <span class=\"label\">CLIENT</span>\n          <p>Xillium LLC</p>\n        </div>\n        <div class=\"meta-item\">\n          <span class=\"label\">ROLE</span>\n          <p>Packaging & Illustration</p>\n        </div>\n        <div class=\"meta-item\">\n          <span class=\"label\">YEAR</span>\n          <p>2026</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"project-media fade-in-up\">\n    <div class=\"container\">\n      <div class=\"media-gallery-grid\">\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://0aozkeng1\" alt=\"2026 Coffee Design Main\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://a636tw879\" alt=\"2026 Coffee Design Kickstarter\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://a0z18s7h5\" alt=\"2026 Coffee Design Black Magic\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://ee9lp38yy\" alt=\"2026 Coffee Design Velvet\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"project-details fade-in-up\">\n    <div class=\"container split-layout\">\n      <div class=\"split-text\">\n        <h2 class=\"section-title\">Design</h2>\n        <ul class=\"bullet-list text-muted mt-1\">\n          <li><strong>The \"Glocal\" Aesthetic:</strong> A sophisticated blend of modern corporate structure and traditional Filipino folk art. The clean, matte-white pouches provide a canvas for vibrant, hand-painted illustrations.</li>\n          <li><strong>Visual Hierarchy:</strong> Functional color-coding (Red, Green, Yellow) defines the roast profile, while bold sans-serif typography maintains the professional identity of the Xillium brand.</li>\n          <li><strong>Storytelling Art:</strong> Each label features a central cultural vignette—Dinagyang, Kamayan, and Bayanihan—connecting the product to themes of celebration, community, and cooperation.</li>\n        </ul>\n      </div>\n      <div class=\"split-text\">\n        <h2 class=\"section-title\">Purpose</h2>\n        <ul class=\"bullet-list text-muted mt-1\">\n          <li><strong>Corporate Identity:</strong> Humanizes a tech-driven brand by aligning it with heritage and hospitality, making it memorable for clients and partners.</li>\n          <li><strong>Strategic Gifting:</strong> Elevates a standard promotional item into a premium \"Heritage Series\" gift set, designed for high-level networking and brand activation.</li>\n          <li><strong>Experiential Marketing:</strong> Uses sensory cues (specialty tasting notes and roast dates) to bridge the gap between a digital enterprise and a tangible, high-quality physical experience.</li>\n        </ul>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"next-project-nav mt-4\">\n    <div class=\"container text-center\">\n      <p class=\"label\">[CONTINUE]</p>\n      <a href=\"project-2025-coffee.html\" class=\"mega-title hover-accent\">Next Project <svg width=\"40\" height=\"40\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1\"><path d=\"M5 12h14M12 5l7 7-7\"/></svg></a>\n    </div>\n  </section>\n</main>\n\n<footer class=\"site-footer\">\n  <div class=\"container\">\n    <div class=\"footer-grid\">\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">MULTIMEDIA DESIGNER</h4>\n        <p class=\"text-muted\">Embracing imperfection.<br>Finding beauty in the raw.</p>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">NAVIGATION</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"index.html\">Home</a></li>\n          <li><a href=\"work.html\">Work</a></li>\n          <li><a href=\"about.html\">About</a></li>\n          <li><a href=\"contact.html\">Contact</a></li>\n        </ul>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">CONNECT</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"https://www.linkedin.com/in/amielnavigar/\" target=\"_blank\" rel=\"noopener noreferrer\">LinkedIn</a></li>\n        </ul>\n      </div>\n    </div>\n    <div class=\"footer-bottom\">\n      <div class=\"copyright\">© 2026</div>\n      <div class=\"quote\">Nothing is permanent.</div>\n    </div>\n  </div>\n</footer>\n\n<div id=\"custom-cursor\" class=\"custom-cursor\"></div>\n<script src=\"script.js\"></script>"},{"name":"project-2025-coffee.html","html":"<title>2025 Coffee Design - Amiel Navigar | Multimedia Designer</title>\n<link rel=\"stylesheet\" href=\"style.css\">\n<div class=\"page-transition\"></div>\n<header id=\"main-header\">\n  <div class=\"container header-inner\">\n    <a href=\"index.html\" class=\"logo\">AMIEL NAVIGAR</a>\n    <nav>\n      <ul class=\"nav-links\">\n        <li><a href=\"index.html\">HOME</a></li>\n        <li><a href=\"work.html\" class=\"active\">WORK</a></li>\n        <li><a href=\"about.html\">ABOUT</a></li>\n        <li><a href=\"contact.html\">CONTACT</a></li>\n        <li>\n          <button id=\"theme-toggle\" class=\"theme-toggle\" aria-label=\"Toggle Theme\">\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"currentColor\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 2v20a10 10 0 1 0 0-20z\"/></svg>\n          </button>\n        </li>\n      </ul>\n    </nav>\n  </div>\n</header>\n\n<main class=\"page-project\">\n  <section class=\"project-hero fade-in-up\">\n    <div class=\"container\">\n      <a href=\"work.html\" class=\"link-btn mb-4\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M19 12H5M12 19l-7-7 7-7\"/></svg> BACK TO WORK</a>\n      \n      <div class=\"label\">[CASE STUDY]</div>\n      <h1 class=\"mega-title\">2025 Coffee<br>Design</h1>\n      \n      <div class=\"project-meta mt-3\">\n        <div class=\"meta-item\">\n          <span class=\"label\">CLIENT</span>\n          <p>Artisanal Roasters</p>\n        </div>\n        <div class=\"meta-item\">\n          <span class=\"label\">ROLE</span>\n          <p>Packaging & Layout</p>\n        </div>\n        <div class=\"meta-item\">\n          <span class=\"label\">YEAR</span>\n          <p>2025</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"project-media fade-in-up\">\n    <div class=\"container\">\n      <div class=\"media-gallery-grid\">\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://cbvmw6hfp\" alt=\"2025 Coffee Design Main\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://rztlfjgg7\" alt=\"2025 Coffee Design Reyjohn Basco\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://k12bvi1ml\" alt=\"2025 Coffee Design Unleashed\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://774v2huqp\" alt=\"2025 Coffee Design Velvet\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"project-details fade-in-up\">\n    <div class=\"container split-layout\">\n      <div class=\"split-text\">\n        <h2 class=\"section-title\">Design Elements</h2>\n        <ul class=\"bullet-list text-muted mt-1\">\n          <li><strong>The Red:</strong> Bold, detailed clusters of ripe coffee cherries dominate the lower half, symbolizing peak flavor and readiness for harvest. This is reinforced by a vertical red divider bar.</li>\n          <li><strong>The Yellow:</strong> A warm, inviting backdrop of a patterned yellow hue suggests the tropical sun and a bright, sunny acidity. Subtly outlined botanical elements add texture without clutter.</li>\n          <li><strong>The Green:</strong> Distinctive green coffee leaves frame the cherry clusters, representing the natural, organic origin and fresh growth.</li>\n        </ul>\n      </div>\n      <div class=\"split-text\">\n        <h2 class=\"section-title\">Purpose</h2>\n        <p class=\"text-muted\">The primary purpose of the design is to establish the coffee's exclusive and artisanal nature. The very small net weight of only 50g instantly signals a rare micro-lot or a special sampler pack. The specific, complex tasting notes are not merely described but presented as essential components, guiding the consumer through the curated flavor profile. The design transforms the label from a simple identification marker into a narrative of quality, care, and origin, elevating the coffee from a commodity to an exclusive experience.</p>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"next-project-nav mt-4\">\n    <div class=\"container text-center\">\n      <p class=\"label\">[CONTINUE]</p>\n      <a href=\"project-2024-coffee.html\" class=\"mega-title hover-accent\">Next Project <svg width=\"40\" height=\"40\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1\"><path d=\"M5 12h14M12 5l7 7-7\"/></svg></a>\n    </div>\n  </section>\n</main>\n\n<footer class=\"site-footer\">\n  <div class=\"container\">\n    <div class=\"footer-grid\">\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">MULTIMEDIA DESIGNER</h4>\n        <p class=\"text-muted\">Embracing imperfection.<br>Finding beauty in the raw.</p>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">NAVIGATION</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"index.html\">Home</a></li>\n          <li><a href=\"work.html\">Work</a></li>\n          <li><a href=\"about.html\">About</a></li>\n          <li><a href=\"contact.html\">Contact</a></li>\n        </ul>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">CONNECT</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"https://www.linkedin.com/in/amielnavigar/\" target=\"_blank\" rel=\"noopener noreferrer\">LinkedIn</a></li>\n        </ul>\n      </div>\n    </div>\n    <div class=\"footer-bottom\">\n      <div class=\"copyright\">© 2026</div>\n      <div class=\"quote\">Nothing is permanent.</div>\n    </div>\n  </div>\n</footer>\n\n<div id=\"custom-cursor\" class=\"custom-cursor\"></div>\n<script src=\"script.js\"></script>"},{"name":"project-2024-coffee.html","html":"<title>2024 Coffee Design - Amiel Navigar | Multimedia Designer</title>\n<link rel=\"stylesheet\" href=\"style.css\">\n<div class=\"page-transition\"></div>\n<header id=\"main-header\">\n  <div class=\"container header-inner\">\n    <a href=\"index.html\" class=\"logo\">AMIEL NAVIGAR</a>\n    <nav>\n      <ul class=\"nav-links\">\n        <li><a href=\"index.html\">HOME</a></li>\n        <li><a href=\"work.html\" class=\"active\">WORK</a></li>\n        <li><a href=\"about.html\">ABOUT</a></li>\n        <li><a href=\"contact.html\">CONTACT</a></li>\n        <li>\n          <button id=\"theme-toggle\" class=\"theme-toggle\" aria-label=\"Toggle Theme\">\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"currentColor\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 2v20a10 10 0 1 0 0-20z\"/></svg>\n          </button>\n        </li>\n      </ul>\n    </nav>\n  </div>\n</header>\n\n<main class=\"page-project\">\n  <section class=\"project-hero fade-in-up\">\n    <div class=\"container\">\n      <a href=\"work.html\" class=\"link-btn mb-4\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M19 12H5M12 19l-7-7 7-7\"/></svg> BACK TO WORK</a>\n      \n      <div class=\"label\">[CASE STUDY]</div>\n      <h1 class=\"mega-title\">2024 Coffee<br>Design</h1>\n      \n      <div class=\"project-meta mt-3\">\n        <div class=\"meta-item\">\n          <span class=\"label\">CLIENT</span>\n          <p>Curated Roasters</p>\n        </div>\n        <div class=\"meta-item\">\n          <span class=\"label\">ROLE</span>\n          <p>Packaging & Print</p>\n        </div>\n        <div class=\"meta-item\">\n          <span class=\"label\">YEAR</span>\n          <p>2024</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"project-media fade-in-up\">\n    <div class=\"container\">\n      <div class=\"media-gallery-grid\">\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://4gw2lx789\" alt=\"2024 Coffee Design Main\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://jgp27redn\" alt=\"2024 Coffee Design Cherry Cabanday\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://qsaxa86pb\" alt=\"2024 Coffee Design Milalittra Natural\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://ptoe8lsln\" alt=\"2024 Coffee Design Marivic Dubria\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"project-details fade-in-up\">\n    <div class=\"container split-layout\">\n      <div class=\"split-text\">\n        <h2 class=\"section-title\">Design Elements</h2>\n        <p class=\"text-muted\">This label design is a sophisticated product sticker intended for a curated coffee pouch, focusing on craftsmanship, authenticity, and technical precision. Visually, the design adopts a \"white minimal\" aesthetic, utilizing a clean white backdrop, elegant navy blue accents, and traditional, detailed botanical illustrations to communicate premium quality and a deep respect for coffee tradition.</p>\n        <ul class=\"bullet-list text-muted mt-1\">\n          <li><strong>The Blueprint Botanical:</strong> The central visual element is a detailed, traditional pen-and-ink style illustration of the coffee plant, rendered in a calming navy blue. This \"blueprint\" style suggests meticulous study, expertise, and an authentic, organic origin. It connects the consumer directly to the farm.</li>\n          <li><strong>The Contrast Header:</strong> A solid navy blue block at the bottom provides a strong structural base. It utilizes bold, clean white typography for essential product details ensuring maximum readability against the minimal top section. A subtle geometric pattern adds texture without distraction.</li>\n        </ul>\n      </div>\n      <div class=\"split-text\">\n        <h2 class=\"section-title\">Purpose</h2>\n        <p class=\"text-muted\">The primary purpose of the white minimal design is to convey unparalleled sophistication and purity. By stripping away excessive color and complex imagery, the label signals that the coffee itself is the star, requiring no gimmicks. The minimal design addresses a discerning consumer who values transparency and authenticity.</p>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"next-project-nav mt-4\">\n    <div class=\"container text-center\">\n      <p class=\"label\">[CONTINUE]</p>\n      <a href=\"project-fall-events.html\" class=\"mega-title hover-accent\">Next Project <svg width=\"40\" height=\"40\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1\"><path d=\"M5 12h14M12 5l7 7-7\"/></svg></a>\n    </div>\n  </section>\n</main>\n\n<footer class=\"site-footer\">\n  <div class=\"container\">\n    <div class=\"footer-grid\">\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">MULTIMEDIA DESIGNER</h4>\n        <p class=\"text-muted\">Embracing imperfection.<br>Finding beauty in the raw.</p>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">NAVIGATION</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"index.html\">Home</a></li>\n          <li><a href=\"work.html\">Work</a></li>\n          <li><a href=\"about.html\">About</a></li>\n          <li><a href=\"contact.html\">Contact</a></li>\n        </ul>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">CONNECT</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"https://www.linkedin.com/in/amielnavigar/\" target=\"_blank\" rel=\"noopener noreferrer\">LinkedIn</a></li>\n        </ul>\n      </div>\n    </div>\n    <div class=\"footer-bottom\">\n      <div class=\"copyright\">© 2026</div>\n      <div class=\"quote\">Nothing is permanent.</div>\n    </div>\n  </div>\n</footer>\n\n<div id=\"custom-cursor\" class=\"custom-cursor\"></div>\n<script src=\"script.js\"></script>"},{"name":"project-business-cards.html","html":"<title>Business Cards - Amiel Navigar | Multimedia Designer</title>\n<link rel=\"stylesheet\" href=\"style.css\">\n<div class=\"page-transition\"></div>\n<header id=\"main-header\">\n  <div class=\"container header-inner\">\n    <a href=\"index.html\" class=\"logo\">AMIEL NAVIGAR</a>\n    <nav>\n      <ul class=\"nav-links\">\n        <li><a href=\"index.html\">HOME</a></li>\n        <li><a href=\"work.html\" class=\"active\">WORK</a></li>\n        <li><a href=\"about.html\">ABOUT</a></li>\n        <li><a href=\"contact.html\">CONTACT</a></li>\n        <li>\n          <button id=\"theme-toggle\" class=\"theme-toggle\" aria-label=\"Toggle Theme\">\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"currentColor\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 2v20a10 10 0 1 0 0-20z\"/></svg>\n          </button>\n        </li>\n      </ul>\n    </nav>\n  </div>\n</header>\n\n<main class=\"page-project\">\n  <section class=\"project-hero fade-in-up\">\n    <div class=\"container\">\n      <a href=\"work.html\" class=\"link-btn mb-4\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M19 12H5M12 19l-7-7 7-7\"/></svg> BACK TO WORK</a>\n      \n      <div class=\"label\">[CASE STUDY]</div>\n      <h1 class=\"mega-title\">Business<br>Cards</h1>\n      \n      <div class=\"project-meta mt-3\">\n        <div class=\"meta-item\">\n          <span class=\"label\">CLIENT</span>\n          <p>Various</p>\n        </div>\n        <div class=\"meta-item\">\n          <span class=\"label\">ROLE</span>\n          <p>Print Design</p>\n        </div>\n        <div class=\"meta-item\">\n          <span class=\"label\">YEAR</span>\n          <p>2025-2026</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"project-media fade-in-up\">\n    <div class=\"container\">\n      <div class=\"media-gallery-grid\">\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://88lvna0af\" alt=\"Business Card Design 1\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://06x3kuhpk\" alt=\"Business Card Design 2\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"project-details fade-in-up\">\n    <div class=\"container split-layout\">\n      <div class=\"split-text\">\n        <h2 class=\"section-title\">The Challenge</h2>\n        <p class=\"text-muted\">Translating a digital aesthetic into a tactile, physical format. The objective was to design business cards that strip away conventional corporate flair, focusing instead on stark typography, raw materials, and structural hierarchy to leave a lasting, immediate impression.</p>\n      </div>\n      <div class=\"split-text\">\n        <h2 class=\"section-title\">The Execution</h2>\n        <p class=\"text-muted\">Employing heavy-stock paper and monochrome palettes, the designs lean heavily on grid systems and sans-serif typefaces. The physical imperfections of the printing process are embraced, turning functional contact information into a brutalist statement piece.</p>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"next-project-nav mt-4\">\n    <div class=\"container text-center\">\n      <p class=\"label\">[CONTINUE]</p>\n      <a href=\"project-2026-coffee.html\" class=\"mega-title hover-accent\">Next Project <svg width=\"40\" height=\"40\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1\"><path d=\"M5 12h14M12 5l7 7-7\"/></svg></a>\n    </div>\n  </section>\n</main>\n\n<footer class=\"site-footer\">\n  <div class=\"container\">\n    <div class=\"footer-grid\">\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">MULTIMEDIA DESIGNER</h4>\n        <p class=\"text-muted\">Embracing imperfection.<br>Finding beauty in the raw.</p>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">NAVIGATION</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"index.html\">Home</a></li>\n          <li><a href=\"work.html\">Work</a></li>\n          <li><a href=\"about.html\">About</a></li>\n          <li><a href=\"contact.html\">Contact</a></li>\n        </ul>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">CONNECT</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"https://www.linkedin.com/in/amielnavigar/\" target=\"_blank\" rel=\"noopener noreferrer\">LinkedIn</a></li>\n        </ul>\n      </div>\n    </div>\n    <div class=\"footer-bottom\">\n      <div class=\"copyright\">© 2026</div>\n      <div class=\"quote\">Nothing is permanent.</div>\n    </div>\n  </div>\n</footer>\n\n<div id=\"custom-cursor\" class=\"custom-cursor\"></div>\n<script src=\"script.js\"></script>"},{"name":"project-lanyards.html","html":"<title>Lanyards 2026 - Amiel Navigar | Multimedia Designer</title>\n<link rel=\"stylesheet\" href=\"style.css\">\n<div class=\"page-transition\"></div>\n<header id=\"main-header\">\n  <div class=\"container header-inner\">\n    <a href=\"index.html\" class=\"logo\">AMIEL NAVIGAR</a>\n    <nav>\n      <ul class=\"nav-links\">\n        <li><a href=\"index.html\">HOME</a></li>\n        <li><a href=\"work.html\" class=\"active\">WORK</a></li>\n        <li><a href=\"about.html\">ABOUT</a></li>\n        <li><a href=\"contact.html\">CONTACT</a></li>\n        <li>\n          <button id=\"theme-toggle\" class=\"theme-toggle\" aria-label=\"Toggle Theme\">\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"currentColor\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 2v20a10 10 0 1 0 0-20z\"/></svg>\n          </button>\n        </li>\n      </ul>\n    </nav>\n  </div>\n</header>\n\n<main class=\"page-project\">\n  <section class=\"project-hero fade-in-up\">\n    <div class=\"container\">\n      <a href=\"work.html\" class=\"link-btn mb-4\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M19 12H5M12 19l-7-7 7-7\"/></svg> BACK TO WORK</a>\n      \n      <div class=\"label\">[CASE STUDY]</div>\n      <h1 class=\"mega-title\">Lanyards 2026<br>Series</h1>\n      \n      <div class=\"project-meta mt-3\">\n        <div class=\"meta-item\">\n          <span class=\"label\">CLIENT</span>\n          <p>Xillium LLC</p>\n        </div>\n        <div class=\"meta-item\">\n          <span class=\"label\">ROLE</span>\n          <p>Brand Identity & Product Design</p>\n        </div>\n        <div class=\"meta-item\">\n          <span class=\"label\">YEAR</span>\n          <p>2026</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"project-media fade-in-up\">\n    <div class=\"container\">\n      <div class=\"media-gallery-grid\">\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://5fy1ee81i\" alt=\"Lanyards 2026 Main Set\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://3ik7k4q35\" alt=\"Lanyards 2026 Tiered Solution\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"project-details fade-in-up\">\n    <div class=\"container split-layout\">\n      <div class=\"split-text\">\n        <h2 class=\"section-title\">The Objective</h2>\n        <p class=\"text-muted\">The goal was to produce a tiered identity solution for a tech-heavy organization. These lanyards aren't just branding; they are functional tools for internal security and role identification. By utilizing industrial patterns and a strict blue/black palette, the design bridges the gap between high-tech infrastructure and physical human assets.</p>\n      </div>\n      <div class=\"split-text\">\n        <h2 class=\"section-title\">Design Tiers</h2>\n        <ul class=\"bullet-list text-muted mt-1\">\n          <li><strong>Corporate Blue:</strong> Minimalist and professional for external representation and standard staff.</li>\n          <li><strong>Data Matrix:</strong> A technical, patterned design for asset control and backend operations.</li>\n          <li><strong>Secure Access:</strong> High-visibility branding for rapid identification in restricted zones.</li>\n        </ul>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"next-project-nav mt-4\">\n    <div class=\"container text-center\">\n      <p class=\"label\">[CONTINUE]</p>\n      <a href=\"work.html\" class=\"mega-title hover-accent\">Back to Gallery <svg width=\"40\" height=\"40\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1\"><path d=\"M5 12h14M12 5l7 7-7\"/></svg></a>\n    </div>\n  </section>\n</main>\n\n<footer class=\"site-footer\">\n  <div class=\"container\">\n    <div class=\"footer-grid\">\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">MULTIMEDIA DESIGNER</h4>\n        <p class=\"text-muted\">Embracing imperfection.<br>Finding beauty in the raw.</p>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">NAVIGATION</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"index.html\">Home</a></li>\n          <li><a href=\"work.html\">Work</a></li>\n          <li><a href=\"about.html\">About</a></li>\n          <li><a href=\"contact.html\">Contact</a></li>\n        </ul>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">CONNECT</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"https://www.linkedin.com/in/amielnavigar/\" target=\"_blank\" rel=\"noopener noreferrer\">LinkedIn</a></li>\n        </ul>\n      </div>\n    </div>\n    <div class=\"footer-bottom\">\n      <div class=\"copyright\">© 2026</div>\n      <div class=\"quote\">Nothing is permanent.</div>\n    </div>\n  </div>\n</footer>\n\n<div id=\"custom-cursor\" class=\"custom-cursor\"></div>\n<script src=\"script.js\"></script>"},{"name":"project-primed-west.html","html":"<title>Primed West 2025 - Amiel Navigar | Multimedia Designer</title>\n<link rel=\"stylesheet\" href=\"style.css\">\n<div class=\"page-transition\"></div>\n<header id=\"main-header\">\n  <div class=\"container header-inner\">\n    <a href=\"index.html\" class=\"logo\">AMIEL NAVIGAR</a>\n    <nav>\n      <ul class=\"nav-links\">\n        <li><a href=\"index.html\">HOME</a></li>\n        <li><a href=\"work.html\" class=\"active\">WORK</a></li>\n        <li><a href=\"about.html\">ABOUT</a></li>\n        <li><a href=\"contact.html\">CONTACT</a></li>\n        <li>\n          <button id=\"theme-toggle\" class=\"theme-toggle\" aria-label=\"Toggle Theme\">\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"currentColor\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 2v20a10 10 0 1 0 0-20z\"/></svg>\n          </button>\n        </li>\n      </ul>\n    </nav>\n  </div>\n</header>\n\n<main class=\"page-project\">\n  <section class=\"project-hero fade-in-up\">\n    <div class=\"container\">\n      <a href=\"work.html\" class=\"link-btn mb-4\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M19 12H5M12 19l-7-7 7-7\"/></svg> BACK TO WORK</a>\n      \n      <div class=\"label\">[CASE STUDY]</div>\n      <h1 class=\"mega-title\">Primed West<br>2025</h1>\n      \n      <div class=\"project-meta mt-3\">\n        <div class=\"meta-item\">\n          <span class=\"label\">CLIENT</span>\n          <p>Corporate Event</p>\n        </div>\n        <div class=\"meta-item\">\n          <span class=\"label\">ROLE</span>\n          <p>Large Print Design</p>\n        </div>\n        <div class=\"meta-item\">\n          <span class=\"label\">YEAR</span>\n          <p>2025</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"project-media fade-in-up\">\n    <div class=\"container\">\n      <div class=\"media-gallery-grid\">\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://zo8o8ahh6\" alt=\"Primed West 2025 Main\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://1d9o4csnu\" alt=\"Primed West 2025 Asset 3\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://4w83czbwc\" alt=\"Primed West 2025 Asset 2\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://fnohtsjcz\" alt=\"Primed West 2025 Asset 1\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"project-details fade-in-up\">\n    <div class=\"container split-layout\">\n      <div class=\"split-text\">\n        <h2 class=\"section-title\">The Challenge</h2>\n        <p class=\"text-muted\">Designing the first backlit panel for a large-scale physical format. The objective was to maintain a minimal, sophisticated, and professional brand approach while ensuring high visibility in a busy exhibition setting.</p>\n      </div>\n      <div class=\"split-text\">\n        <h2 class=\"section-title\">The Execution</h2>\n        <p class=\"text-muted\">Utilizing a refined layout and stark contrasts, the panel strips away excess visual noise. The intentional restraint ensures the primary messaging remains authoritative, clear, and commands attention without relying on gimmickry.</p>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"next-project-nav mt-4\">\n    <div class=\"container text-center\">\n      <p class=\"label\">[CONTINUE]</p>\n      <a href=\"project-primed-east.html\" class=\"mega-title hover-accent\">Next Project <svg width=\"40\" height=\"40\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1\"><path d=\"M5 12h14M12 5l7 7-7\"/></svg></a>\n    </div>\n  </section>\n</main>\n\n<footer class=\"site-footer\">\n  <div class=\"container\">\n    <div class=\"footer-grid\">\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">MULTIMEDIA DESIGNER</h4>\n        <p class=\"text-muted\">Embracing imperfection.<br>Finding beauty in the raw.</p>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">NAVIGATION</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"index.html\">Home</a></li>\n          <li><a href=\"work.html\">Work</a></li>\n          <li><a href=\"about.html\">About</a></li>\n          <li><a href=\"contact.html\">Contact</a></li>\n        </ul>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">CONNECT</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"https://www.linkedin.com/in/amielnavigar/\" target=\"_blank\" rel=\"noopener noreferrer\">LinkedIn</a></li>\n        </ul>\n      </div>\n    </div>\n    <div class=\"footer-bottom\">\n      <div class=\"copyright\">© 2026</div>\n      <div class=\"quote\">Nothing is permanent.</div>\n    </div>\n  </div>\n</footer>\n\n<div id=\"custom-cursor\" class=\"custom-cursor\"></div>\n<script src=\"script.js\"></script>"},{"name":"project-primed-east.html","html":"<title>Primed East 2025 - Amiel Navigar | Multimedia Designer</title>\n<link rel=\"stylesheet\" href=\"style.css\">\n<div class=\"page-transition\"></div>\n<header id=\"main-header\">\n  <div class=\"container header-inner\">\n    <a href=\"index.html\" class=\"logo\">AMIEL NAVIGAR</a>\n    <nav>\n      <ul class=\"nav-links\">\n        <li><a href=\"index.html\">HOME</a></li>\n        <li><a href=\"work.html\" class=\"active\">WORK</a></li>\n        <li><a href=\"about.html\">ABOUT</a></li>\n        <li><a href=\"contact.html\">CONTACT</a></li>\n        <li>\n          <button id=\"theme-toggle\" class=\"theme-toggle\" aria-label=\"Toggle Theme\">\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"currentColor\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 2v20a10 10 0 1 0 0-20z\"/></svg>\n          </button>\n        </li>\n      </ul>\n    </nav>\n  </div>\n</header>\n\n<main class=\"page-project\">\n  <section class=\"project-hero fade-in-up\">\n    <div class=\"container\">\n      <a href=\"work.html\" class=\"link-btn mb-4\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M19 12H5M12 19l-7-7 7-7\"/></svg> BACK TO WORK</a>\n      \n      <div class=\"label\">[CASE STUDY]</div>\n      <h1 class=\"mega-title\">Primed East<br>2025</h1>\n      \n      <div class=\"project-meta mt-3\">\n        <div class=\"meta-item\">\n          <span class=\"label\">CLIENT</span>\n          <p>Corporate Event</p>\n        </div>\n        <div class=\"meta-item\">\n          <span class=\"label\">ROLE</span>\n          <p>Large Print Design</p>\n        </div>\n        <div class=\"meta-item\">\n          <span class=\"label\">YEAR</span>\n          <p>2025</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"project-media fade-in-up\">\n    <div class=\"container\">\n      <div class=\"media-gallery-grid\">\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://6cudbxxuy\" alt=\"Primed East 2025 Main\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://s2s1of9ul\" alt=\"Primed East 2025 Panel\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"project-details fade-in-up\">\n    <div class=\"container split-layout\">\n      <div class=\"split-text\">\n        <h2 class=\"section-title\">The Challenge</h2>\n        <p class=\"text-muted\">Designing a 10x10 conference booth panel intended to stand out. The main purpose was to ensure the brand could pop and retain authority amidst a chaotic environment filled with various, clashing colors from neighboring booths.</p>\n      </div>\n      <div class=\"split-text\">\n        <h2 class=\"section-title\">The Execution</h2>\n        <p class=\"text-muted\">By employing bold, high-contrast visual structures and a strict adherence to the brand's core aesthetics, the booth design cuts through the surrounding visual clutter. It prioritizes function and direct impact over decorative elements.</p>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"next-project-nav mt-4\">\n    <div class=\"container text-center\">\n      <p class=\"label\">[CONTINUE]</p>\n      <a href=\"project-primed-west.html\" class=\"mega-title hover-accent\">Next Project <svg width=\"40\" height=\"40\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1\"><path d=\"M5 12h14M12 5l7 7-7\"/></svg></a>\n    </div>\n  </section>\n</main>\n\n<footer class=\"site-footer\">\n  <div class=\"container\">\n    <div class=\"footer-grid\">\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">MULTIMEDIA DESIGNER</h4>\n        <p class=\"text-muted\">Embracing imperfection.<br>Finding beauty in the raw.</p>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">NAVIGATION</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"index.html\">Home</a></li>\n          <li><a href=\"work.html\">Work</a></li>\n          <li><a href=\"about.html\">About</a></li>\n          <li><a href=\"contact.html\">Contact</a></li>\n        </ul>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">CONNECT</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"https://www.linkedin.com/in/amielnavigar/\" target=\"_blank\" rel=\"noopener noreferrer\">LinkedIn</a></li>\n        </ul>\n      </div>\n    </div>\n    <div class=\"footer-bottom\">\n      <div class=\"copyright\">© 2026</div>\n      <div class=\"quote\">Nothing is permanent.</div>\n    </div>\n  </div>\n</footer>\n\n<div id=\"custom-cursor\" class=\"custom-cursor\"></div>\n<script src=\"script.js\"></script>"}],"css":"@import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600&family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&family=Syne:wght@400;600;700;800&display=swap');\n\n:root, [data-theme=\"dark\"], body[data-theme=\"dark\"] {\n  var(--bg-color): #161616;\n  --bg-color: #161616;\n  --surface-color: #1a1a1a;\n  --text-primary: #f0f0f0;\n  --text-muted: #888888;\n  --accent-color: #d65a31;\n  --border-color: #333333;\n  --grid-opacity: 0.02;\n  --glass-bg: rgba(22, 22, 22, 0.7);\n  \n  --font-serif: 'Syne', sans-serif;\n  --font-sans: 'Manrope', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n  --font-mono: 'Space Mono', 'Courier New', Courier, monospace;\n}\n\n:root[data-theme=\"light\"], [data-theme=\"light\"], body[data-theme=\"light\"] {\n  --bg-color: #f4f4f0;\n  --surface-color: #e8e8e4;\n  --text-primary: #0a0a0a;\n  --text-muted: #555555;\n  --accent-color: #ff3300;\n  --border-color: #c0c0bc;\n  --grid-opacity: 0.06;\n  --glass-bg: rgba(244, 244, 240, 0.8);\n}\n\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nbody {\n  background-color: var(--bg-color);\n  background-image: \n    linear-gradient(rgba(150, 150, 150, var(--grid-opacity)) 1px, transparent 1px),\n    linear-gradient(90deg, rgba(150, 150, 150, var(--grid-opacity)) 1px, transparent 1px);\n  background-size: 40px 40px;\n  background-attachment: fixed;\n  color: var(--text-primary);\n  font-family: var(--font-sans);\n  line-height: 1.6;\n  overflow-x: hidden;\n  transition: background-color 0.3s ease, color 0.3s ease;\n}\n\n/* Paper Texture Overlay */\nbody::before {\n  content: \"\";\n  position: fixed;\n  inset: 0;\n  z-index: 9990;\n  pointer-events: none;\n  background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.7' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E\");\n  opacity: 0.05;\n  mix-blend-mode: overlay;\n}\n\n[data-theme=\"light\"] body::before, body[data-theme=\"light\"]::before, :root[data-theme=\"light\"] body::before {\n  opacity: 0.07;\n  mix-blend-mode: multiply;\n}\n\nimg, svg, video {\n  max-width: 100%;\n  display: block;\n}\n\na {\n  color: inherit;\n  text-decoration: none;\n  transition: color 0.3s ease;\n}\n\n/* Keyboard Accessibility */\na:focus-visible, button:focus-visible, input:focus-visible, textarea:focus-visible {\n  outline: 2px solid var(--accent-color);\n  outline-offset: 4px;\n}\n\nul {\n  list-style: none;\n}\n\n/* Page Transitions */\n.page-transition {\n  position: fixed;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100vh;\n  background-color: var(--surface-color);\n  z-index: 999999;\n  pointer-events: none;\n  transform-origin: top;\n  transform: scaleY(1);\n  transition: transform 0.6s cubic-bezier(0.85, 0, 0.15, 1);\n}\n.page-transition.is-loaded {\n  transform: scaleY(0);\n  transform-origin: bottom;\n}\n.page-transition.is-leaving {\n  transform: scaleY(1);\n  transform-origin: top;\n}\n\n/* Page Loader */\n.page-loader {\n  position: fixed;\n  inset: 0;\n  background-color: var(--bg-color);\n  z-index: 999990;\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n  align-items: center;\n  transition: opacity 0.6s ease, visibility 0.6s ease;\n}\n.page-loader.is-hidden {\n  opacity: 0;\n  visibility: hidden;\n}\n.loader-track {\n  width: 200px;\n  height: 2px;\n  background-color: var(--border-color);\n  overflow: hidden;\n}\n.loader-bar {\n  width: 0%;\n  height: 100%;\n  background-color: var(--accent-color);\n  transition: width 0.3s cubic-bezier(0.16, 1, 0.3, 1);\n}\n\n/* Custom Cursor */\n@media (pointer: fine) {\n  body, a, button, .asset-box, input, textarea, .hover-trigger {\n    cursor: none;\n  }\n}\n.custom-cursor {\n  position: fixed;\n  top: 0;\n  left: 0;\n  width: 12px;\n  height: 12px;\n  background-color: var(--accent-color);\n  transform: translate(-50%, -50%);\n  pointer-events: none;\n  z-index: 99999;\n  transition: background-color 0.2s, width 0.2s, height 0.2s, border-radius 0.2s, border 0.2s;\n  mix-blend-mode: difference;\n}\n.custom-cursor.hover {\n  width: 48px;\n  height: 48px;\n  background-color: transparent;\n  border: 1.5px solid var(--accent-color);\n  border-radius: 50%;\n}\n@media (pointer: coarse) {\n  .custom-cursor { display: none !important; }\n}\n\n/* Typography */\nh1, h2, h3, h4 {\n  font-family: var(--font-serif);\n  font-weight: 700;\n  line-height: 1.1;\n  letter-spacing: -0.02em;\n}\n.label {\n  font-family: var(--font-mono);\n  color: var(--accent-color);\n  font-size: 0.75rem;\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n  margin-bottom: 1rem;\n}\n.accent-italic {\n  color: var(--accent-color);\n  font-style: italic;\n}\n.text-muted {\n  color: var(--text-muted);\n  transition: color 0.3s ease;\n}\n.mono-text {\n  font-family: var(--font-mono);\n  font-size: 0.85rem;\n}\n.text-sm { font-size: 0.9rem; }\n.text-lg { font-size: 1.15rem; }\n.display-xl {\n  font-size: clamp(3.5rem, 9vw, 9rem);\n  line-height: 0.95;\n  margin-bottom: 1rem;\n  text-transform: uppercase;\n}\n.accent-outline {\n  color: transparent;\n  -webkit-text-stroke: 1.5px var(--text-primary);\n  font-style: italic;\n  font-family: var(--font-serif);\n}\n.mega-title { font-size: clamp(3rem, 6vw, 5rem); }\n.large-heading { font-size: clamp(2.5rem, 5vw, 4rem); }\n.text-huge { font-size: clamp(2rem, 4vw, 3.5rem); }\n\n/* Layout Utilities */\n.container { width: 90%; max-width: 1280px; margin: 0 auto; }\nmain { padding-top: 120px; min-height: calc(100vh - 200px); }\nsection { padding: 4rem 0; }\n\n.mt-1 { margin-top: 1rem; }\n.mt-2 { margin-top: 2rem; }\n.mt-3 { margin-top: 3rem; }\n.mt-4 { margin-top: 5rem; }\n.mb-0 { margin-bottom: 0 !important; }\n.mb-1 { margin-bottom: 0.5rem; }\n.mb-2 { margin-bottom: 1.5rem; }\n.mb-3 { margin-bottom: 3rem; }\n.mb-4 { margin-bottom: 5rem; }\n.pb-4 { padding-bottom: 5rem; }\n.py-2 { padding-top: 2rem; padding-bottom: 2rem; }\n\n.text-center { text-align: center; }\n.text-right { text-align: right; }\n.align-right { text-align: right; }\n.max-w-sm { max-width: 450px; }\n.max-w-md { max-width: 600px; }\n\n.hidden { display: none !important; }\n.block { display: block; }\n.inline-block { display: inline-block; }\n.flex { display: flex; }\n.inline-flex { display: inline-flex; }\n.flex-wrap { flex-wrap: wrap; }\n.flex-col { flex-direction: column; }\n.items-center { align-items: center; }\n.items-end { align-items: flex-end; }\n.items-start { align-items: flex-start; }\n.justify-between { justify-content: space-between; }\n.justify-center { justify-content: center; }\n.gap-2 { gap: 0.5rem; }\n.w-full { width: 100%; }\n.h-full { height: 100%; }\n.relative { position: relative; }\n.absolute { position: absolute; }\n.inset-0 { top: 0; right: 0; bottom: 0; left: 0; }\n.overflow-hidden { overflow: hidden; }\n.border-t { border-top: 1px solid var(--border-color); }\n.border-y { border-top: 1px solid var(--border-color); border-bottom: 1px solid var(--border-color); }\n.border-b-0 { border-bottom: none !important; }\n\n.flex-row-responsive {\n  display: flex;\n  flex-direction: column;\n  gap: 2rem;\n}\n@media (min-width: 768px) {\n  .flex-row-responsive {\n    flex-direction: row;\n    justify-content: space-between;\n    align-items: flex-end;\n  }\n}\n\n.hidden-desktop { display: none; }\n@media(max-width: 767px) {\n  .hidden-mobile { display: none; }\n  .hidden-desktop { display: block; }\n}\n\n/* Header */\n#main-header {\n  position: fixed;\n  top: 0;\n  left: 0;\n  width: 100%;\n  z-index: 1000;\n  padding: 1.5rem 0;\n  transition: all 0.4s ease;\n  border-bottom: 1px solid transparent;\n}\n#main-header.scrolled {\n  background: var(--glass-bg);\n  backdrop-filter: blur(12px);\n  -webkit-backdrop-filter: blur(12px);\n  border-bottom: 1px solid var(--border-color);\n  padding: 1rem 0;\n}\n.header-inner { display: flex; justify-content: space-between; align-items: center; position: relative; }\n.logo { font-family: var(--font-mono); font-weight: bold; letter-spacing: 0.1em; font-size: 0.9rem; }\n.nav-links { display: flex; gap: 2rem; align-items: center; font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 0.05em; }\n.nav-links a:hover, .nav-links a.active { color: var(--accent-color); }\n.theme-toggle {\n  background: none;\n  border: 1px solid var(--border-color);\n  color: var(--text-primary);\n  border-radius: 50%;\n  width: 30px;\n  height: 30px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  cursor: pointer;\n  transition: all 0.3s ease;\n}\n.theme-toggle:hover { border-color: var(--accent-color); color: var(--accent-color); }\n\n@media (max-width: 768px) {\n  .header-inner {\n    flex-direction: column;\n    align-items: flex-start;\n    gap: 0.75rem;\n  }\n  nav {\n    width: 100%;\n    overflow-x: auto;\n    -webkit-overflow-scrolling: touch;\n    scrollbar-width: none;\n    -ms-overflow-style: none;\n    mask-image: linear-gradient(to right, black 85%, transparent 100%);\n    -webkit-mask-image: linear-gradient(to right, black 85%, transparent 100%);\n  }\n  nav::-webkit-scrollbar { display: none; }\n  .nav-links {\n    width: max-content;\n    gap: 1.5rem;\n    padding-bottom: 0.25rem;\n    padding-right: 2rem;\n  }\n  .nav-links li:last-child {\n    position: absolute;\n    top: 0;\n    right: 0;\n  }\n}\n\n/* Elements */\n.marquee {\n  width: 100%;\n  overflow: hidden;\n  background: var(--text-primary);\n  color: var(--bg-color);\n  display: flex;\n  white-space: nowrap;\n  transition: background-color 0.3s ease, color 0.3s ease;\n  transform: rotate(-2deg) scale(1.05);\n  transform-origin: center;\n  position: relative;\n  z-index: 10;\n}\n.marquee-content { display: flex; animation: marquee-scroll 25s linear infinite; }\n.marquee-text {\n  font-family: var(--font-mono);\n  font-size: 1.2rem;\n  font-weight: 700;\n  text-transform: uppercase;\n  padding: 0 1rem;\n  letter-spacing: 0.05em;\n}\n@keyframes marquee-scroll {\n  0% { transform: translateX(0); }\n  100% { transform: translateX(-50%); }\n}\n\n.pulsing-dot {\n  width: 8px;\n  height: 8px;\n  background-color: var(--accent-color);\n  border-radius: 50%;\n  display: inline-block;\n  animation: pulse 2s infinite;\n}\n@keyframes pulse {\n  0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(214, 90, 49, 0.7); }\n  70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(214, 90, 49, 0); }\n  100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(214, 90, 49, 0); }\n}\n\n/* Buttons */\n.link-btn {\n  display: inline-flex;\n  align-items: center;\n  gap: 0.5rem;\n  font-family: var(--font-mono);\n  font-size: 0.8rem;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  border-bottom: 1px solid transparent;\n  padding-bottom: 0.2rem;\n  transition: border-color 0.3s ease;\n}\n.link-btn:hover { border-color: var(--text-primary); }\n\n.btn-outline {\n  display: inline-flex;\n  align-items: center;\n  gap: 0.5rem;\n  font-family: var(--font-mono);\n  font-size: 0.8rem;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  border: 1px solid var(--border-color);\n  padding: 1rem 2rem;\n  background: transparent;\n  color: var(--text-primary);\n  cursor: pointer;\n  transition: all 0.3s ease;\n}\n.btn-outline:hover { border-color: var(--text-primary); background: var(--text-primary); color: var(--bg-color); }\n\n.circle-btn {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  width: 120px;\n  height: 120px;\n  border-radius: 50%;\n  border: 1px solid var(--border-color);\n  background: var(--surface-color);\n  color: var(--text-primary);\n  text-align: center;\n  font-family: var(--font-mono);\n  font-size: 0.75rem;\n  letter-spacing: 0.05em;\n  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);\n  gap: 0.5rem;\n}\n.circle-btn:hover {\n  background: var(--accent-color);\n  border-color: var(--accent-color);\n  color: #fff;\n  transform: scale(1.05);\n}\n\n.back-to-top {\n  position: fixed;\n  bottom: 2rem;\n  right: 2rem;\n  width: 48px;\n  height: 48px;\n  background: var(--surface-color);\n  border: 1px solid var(--border-color);\n  color: var(--text-primary);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  cursor: pointer;\n  z-index: 999;\n  opacity: 0;\n  visibility: hidden;\n  transition: all 0.3s ease;\n  border-radius: 50%;\n}\n.back-to-top.is-visible {\n  opacity: 1;\n  visibility: visible;\n}\n.back-to-top:hover {\n  background: var(--accent-color);\n  border-color: var(--accent-color);\n  color: #fff;\n  transform: translateY(-5px);\n}\n@media (max-width: 768px) {\n  .back-to-top {\n    bottom: 1rem;\n    right: 1rem;\n    width: 40px;\n    height: 40px;\n  }\n}\n\n/* Asset Box */\n.asset-box {\n  display: block;\n  position: relative;\n  background-color: var(--surface-color);\n  border: 1px solid rgba(214, 90, 49, 0.4);\n  aspect-ratio: 16/9;\n  overflow: hidden;\n  background-image: \n    linear-gradient(rgba(150,150,150, var(--grid-opacity)) 1px, transparent 1px),\n    linear-gradient(90deg, rgba(150,150,150, var(--grid-opacity)) 1px, transparent 1px);\n  background-size: 30px 30px;\n  transition: border-color 0.3s ease, background-color 0.3s ease;\n}\n.asset-box:hover { border-color: var(--accent-color); }\n\n.asset-media {\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  z-index: 1;\n  pointer-events: none;\n}\n.parallax-img {\n  transform: scale(1.2);\n  transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), filter 0.4s ease;\n}\n.asset-box:hover .parallax-img { transform: scale(1.1); }\n\n.grayscale-reveal .asset-media {\n  filter: grayscale(100%);\n}\n.grayscale-reveal:hover .asset-media {\n  filter: grayscale(0%);\n}\n\n.corner {\n  position: absolute;\n  width: 15px;\n  height: 15px;\n  border-color: rgba(214, 90, 49, 0.4);\n  border-style: solid;\n  border-width: 0;\n  z-index: 2;\n  transition: border-color 0.3s ease;\n}\n.asset-box:hover .corner { border-color: var(--accent-color); }\n.corner-tl { top: 1.5rem; left: 1.5rem; border-top-width: 1px; border-left-width: 1px; }\n.corner-tr { top: 1.5rem; right: 1.5rem; border-top-width: 1px; border-right-width: 1px; }\n.corner-bl { bottom: 1.5rem; left: 1.5rem; border-bottom-width: 1px; border-left-width: 1px; }\n.corner-br { bottom: 1.5rem; right: 1.5rem; border-bottom-width: 1px; border-right-width: 1px; }\n\n.crosshair {\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  width: 20px;\n  height: 20px;\n  z-index: 2;\n}\n.crosshair::before, .crosshair::after {\n  content: '';\n  position: absolute;\n  background-color: rgba(214, 90, 49, 0.4);\n  transition: background-color 0.3s ease;\n}\n.asset-box:hover .crosshair::before, .asset-box:hover .crosshair::after {\n  background-color: var(--accent-color);\n}\n.crosshair::before { top: 50%; left: 0; width: 100%; height: 1px; }\n.crosshair::after { left: 50%; top: 0; height: 100%; width: 1px; }\n\n.project-hover {\n  position: absolute;\n  inset: 0;\n  background: linear-gradient(to top, rgba(0, 0, 0, 0.85) 0%, transparent 40%);\n  display: flex;\n  flex-direction: column;\n  justify-content: flex-end;\n  padding: 2rem;\n  opacity: 0;\n  transition: opacity 0.4s ease, transform 0.4s ease;\n  transform: translateY(10px);\n  z-index: 10;\n  color: #f0f0f0;\n}\n.asset-box:hover .project-hover { opacity: 1; transform: translateY(0); }\n.project-title {\n  font-family: var(--font-mono);\n  font-size: 1.1rem;\n  font-weight: 700;\n  margin-bottom: 0.5rem;\n  letter-spacing: 0.05em;\n}\n.project-year {\n  font-family: var(--font-mono);\n  font-size: 0.75rem;\n  color: #aaa;\n  text-transform: uppercase;\n}\n\n/* Grids & Layouts */\n.bento-grid { display: grid; grid-template-columns: 1fr; gap: 2rem; }\n@media (min-width: 768px) {\n  .bento-grid { grid-template-columns: repeat(6, 1fr); }\n  .span-4 { grid-column: span 4; }\n  .span-3 { grid-column: span 3; }\n  .span-2 { grid-column: span 2; }\n  .span-full { grid-column: 1 / -1; }\n}\n\n.split-layout { display: grid; grid-template-columns: 1fr; gap: 4rem; }\n@media (min-width: 900px) {\n  .split-layout { grid-template-columns: 1fr 1fr; }\n  .align-center { align-items: center; }\n}\n\n.box-tall { aspect-ratio: 3/4; }\n.box-square { aspect-ratio: 1/1; }\n\n/* Capabilities Interactive List */\n.interactive-list { border-top: 1px solid var(--border-color); }\n.list-item {\n  display: grid;\n  grid-template-columns: auto 1fr auto;\n  align-items: center;\n  gap: 2rem;\n  padding: 3rem 0;\n  border-bottom: 1px solid var(--border-color);\n  position: relative;\n  cursor: pointer;\n  transition: padding-left 0.4s ease, padding-right 0.4s ease;\n}\n@media (min-width: 768px) { .list-item { grid-template-columns: auto 2fr 1fr auto; } }\n.list-title { margin-bottom: 0; transition: color 0.3s ease; }\n.list-desc { margin-bottom: 0; }\n.list-arrow { opacity: 0; transform: translateX(-20px); transition: all 0.4s ease; }\n@media (min-width: 768px) {\n  .list-item:hover { padding-left: 2rem; padding-right: 2rem; }\n  .list-item:hover .list-title { color: var(--accent-color); }\n  .list-item:hover .list-arrow { opacity: 1; transform: translateX(0); }\n}\n\n/* Project Specifics */\n.project-meta { display: flex; gap: 3rem; border-top: 1px solid var(--border-color); padding-top: 1.5rem; flex-wrap: wrap; }\n.meta-item p { font-weight: 500; font-size: 1.1rem; }\n\n.media-showcase {\n  position: relative;\n  background-color: var(--surface-color);\n  border: 1px solid rgba(214, 90, 49, 0.4);\n  padding: 2rem;\n  background-image: \n    linear-gradient(rgba(150,150,150, var(--grid-opacity)) 1px, transparent 1px),\n    linear-gradient(90deg, rgba(150,150,150, var(--grid-opacity)) 1px, transparent 1px);\n  background-size: 30px 30px;\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  transition: border-color 0.3s ease;\n}\n.media-showcase:hover { border-color: var(--accent-color); }\n.media-showcase .corner { border-color: rgba(214, 90, 49, 0.4); }\n.media-showcase:hover .corner { border-color: var(--accent-color); }\n.media-showcase-inner { position: relative; z-index: 1; display: flex; justify-content: center; align-items: center; width: 100%; height: 100%; }\n.asset-media-contain { max-width: 100%; max-height: 70vh; object-fit: contain; }\n\n.media-gallery-grid { display: grid; grid-template-columns: 1fr; gap: 2rem; }\n@media (min-width: 768px) { .media-gallery-grid { grid-template-columns: repeat(2, 1fr); } }\n\n/* Work Page */\n.filter-bar {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 0.5rem;\n  border-bottom: 1px solid var(--border-color);\n  padding-bottom: 1.5rem;\n}\n@media (min-width: 768px) {\n  .filter-bar {\n    gap: 0.75rem;\n  }\n}\n\n.filter-btn {\n  background: transparent;\n  border: 1px solid var(--border-color);\n  color: var(--text-primary);\n  padding: 0.4rem 0.8rem;\n  font-family: var(--font-mono);\n  font-size: 0.65rem;\n  cursor: pointer;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  transition: all 0.3s ease;\n  white-space: nowrap;\n  opacity: 0.6;\n  flex-grow: 1;\n  text-align: center;\n}\n@media (min-width: 768px) {\n  .filter-btn {\n    flex-grow: 0;\n    padding: 0.5rem 1.2rem;\n    font-size: 0.75rem;\n  }\n}\n.filter-btn:hover {\n  opacity: 1;\n  border-color: var(--text-primary);\n}\n.filter-btn.active {\n  opacity: 1;\n  background: var(--text-primary);\n  color: var(--bg-color);\n  border-color: var(--text-primary);\n}\n\n.gallery-grid { display: grid; grid-template-columns: 1fr; gap: 2rem; }\n@media (min-width: 600px) { .gallery-grid { grid-template-columns: repeat(2, 1fr); } }\n@media (min-width: 1024px) { .gallery-grid { grid-template-columns: repeat(3, 1fr); } }\n\n/* About Page */\n.bio-text p { margin-bottom: 1.5rem; }\n.box-portrait { aspect-ratio: 3/4; max-width: 500px; margin: 0 auto; }\n.exp-list { border-top: 1px solid var(--border-color); }\n.exp-item { display: flex; justify-content: space-between; align-items: center; padding: 2rem 0; border-bottom: 1px solid var(--border-color); }\n.exp-role { font-weight: 600; font-family: var(--font-sans); }\n.exp-date { margin-bottom: 0; }\n.exp-item-detailed { flex-direction: column; align-items: flex-start; }\n.exp-header { display: flex; justify-content: space-between; align-items: center; width: 100%; }\n.exp-details { max-width: 800px; }\n.bullet-list { list-style-type: square; padding-left: 1.5rem; margin-top: 0.5rem; }\n.bullet-list li { margin-bottom: 0.5rem; }\n\n.tags-container { display: flex; flex-wrap: wrap; gap: 0.5rem; }\n.tag {\n  display: inline-block;\n  border: 1px solid var(--border-color);\n  padding: 0.4rem 0.8rem;\n  font-family: var(--font-mono);\n  font-size: 0.7rem;\n  color: var(--text-muted);\n  transition: border-color 0.3s ease, color 0.3s ease, background-color 0.3s ease;\n}\n.tag:hover { border-color: var(--text-primary); color: var(--bg-color); background-color: var(--text-primary); }\n\n.grid-3 { display: grid; grid-template-columns: 1fr; gap: 2rem; }\n@media (min-width: 768px) { .grid-3 { grid-template-columns: repeat(3, 1fr); } }\n.info-card { border: 1px solid var(--border-color); padding: 2rem; background: var(--surface-color); transition: border-color 0.3s ease, background-color 0.3s ease; }\n.card-title { font-family: var(--font-serif); font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem; }\n\n/* Contact Page */\n.split-layout-contact { display: grid; grid-template-columns: 1fr; gap: 4rem; }\n@media (min-width: 900px) { .split-layout-contact { grid-template-columns: 1fr 1fr; } }\n.contact-item { display: flex; align-items: center; gap: 1rem; }\n.contact-item .label { margin-bottom: 0; }\n.contact-form .form-group { margin-bottom: 2rem; }\n.contact-form input, .contact-form textarea {\n  width: 100%;\n  background: transparent;\n  border: none;\n  border-bottom: 1px solid var(--border-color);\n  padding: 0.5rem 0 1rem 0;\n  color: var(--text-primary);\n  font-family: var(--font-sans);\n  font-size: 1rem;\n  transition: border-color 0.3s ease;\n  resize: none;\n}\n.contact-form input:focus, .contact-form textarea:focus { outline: none; border-color: var(--accent-color); }\n.contact-form input::placeholder, .contact-form textarea::placeholder { color: var(--text-muted); }\n\n/* Footer */\n.site-footer { border-top: 1px solid var(--border-color); padding: 4rem 0 2rem 0; margin-top: 4rem; }\n.footer-grid { display: grid; grid-template-columns: 1fr; gap: 3rem; margin-bottom: 4rem; }\n@media (min-width: 600px) { .footer-grid { grid-template-columns: repeat(2, 1fr); } }\n@media (min-width: 900px) { .footer-grid { grid-template-columns: 2fr 1fr 1fr; } }\n.footer-heading { font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted); margin-bottom: 1.5rem; letter-spacing: 0.1em; }\n.footer-links li { margin-bottom: 0.5rem; }\n.footer-links a { font-family: var(--font-mono); font-size: 0.85rem; color: var(--text-muted); }\n.footer-links a:hover { color: var(--text-primary); }\n.footer-bottom { display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--border-color); padding-top: 2rem; font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted); }\n\n/* Animations */\n.fade-in-up {\n  opacity: 0;\n  transform: translateY(30px);\n  transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);\n}\n.fade-in-up.is-visible { opacity: 1; transform: translateY(0); }\n\n.reveal-text {\n  display: block;\n  transform: translateY(100%);\n  transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1);\n}\n.is-visible .reveal-text {\n  transform: translateY(0);\n}\n.stagger-1 { transition-delay: 0.1s; }\n.stagger-2 { transition-delay: 0.2s; }\n","js":"function getSafeTheme() {\n  try {\n    return localStorage.getItem('theme') || 'dark';\n  } catch (error) {\n    console.warn('localStorage is unavailable, falling back to dark mode.');\n    return 'dark';\n  }\n}\n\nfunction setSafeTheme(theme) {\n  try {\n    localStorage.setItem('theme', theme);\n  } catch (error) {\n    console.warn('localStorage is unavailable, could not save theme preference.');\n  }\n}\n\nconst currentTheme = getSafeTheme();\ndocument.documentElement.setAttribute('data-theme', currentTheme);\n\ndocument.addEventListener('DOMContentLoaded', () => {\n  const titleTag = document.querySelector('title');\n  if (titleTag && titleTag.textContent) {\n    document.title = titleTag.textContent;\n  }\n\n  const themeBtn = document.getElementById('theme-toggle');\n  \n  if (document.body) {\n    document.body.setAttribute('data-theme', currentTheme);\n  }\n\n  if (themeBtn) {\n    themeBtn.addEventListener('click', (e) => {\n      e.preventDefault();\n      const existingTheme = document.documentElement.getAttribute('data-theme') || 'dark';\n      const newTheme = existingTheme === 'dark' ? 'light' : 'dark';\n      \n      document.documentElement.setAttribute('data-theme', newTheme);\n      if (document.body) {\n        document.body.setAttribute('data-theme', newTheme);\n      }\n      setSafeTheme(newTheme);\n    });\n  }\n\n  const transitionEl = document.querySelector('.page-transition');\n  if (transitionEl) {\n    setTimeout(() => {\n      transitionEl.classList.add('is-loaded');\n    }, 150);\n  }\n\n  const header = document.getElementById('main-header');\n  const handleScroll = () => {\n    if (window.scrollY > 50) {\n      header.classList.add('scrolled');\n    } else {\n      header.classList.remove('scrolled');\n    }  \n  };\n  window.addEventListener('scroll', handleScroll, { passive: true });\n  handleScroll();\n\n  // Unified Observer for fade-ins and stagger animations\n  const observerOptions = {\n    root: null,\n    rootMargin: '0px 0px -50px 0px',\n    threshold: 0.1\n  };\n  const observer = new IntersectionObserver((entries, observer) => {\n    entries.forEach(entry => {\n      if (entry.isIntersecting) {\n        entry.target.classList.add('is-visible');\n        observer.unobserve(entry.target);\n      }\n    });\n  }, observerOptions);\n  \n  const animatedElements = document.querySelectorAll('.fade-in-up, .slide-up-group');\n  animatedElements.forEach(el => observer.observe(el));\n\n  // Work Page Loader & Staggered Row Animation\n  const pageLoader = document.getElementById('page-loader');\n  if (pageLoader) {\n    const assetBoxes = Array.from(document.querySelectorAll('.page-work .asset-box'));\n    \n    // Set initial state for stagger animation\n    assetBoxes.forEach(box => {\n      box.style.opacity = '0';\n      box.style.transform = 'translateY(30px)';\n      box.style.transition = 'opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1)';\n    });\n\n    const mediaElements = Array.from(document.querySelectorAll('.page-work .asset-media'));\n    \n    // Optimize videos by preventing simultaneous loading\n    const videoElements = mediaElements.filter(el => el.tagName.toLowerCase() === 'video');\n    videoElements.forEach((vid, index) => {\n      if (index > 3) {\n        vid.removeAttribute('autoplay');\n        vid.setAttribute('preload', 'none');\n      }\n    });\n\n    // Setup Intersection Observer to animate items row by row\n    const animateObserver = new IntersectionObserver((entries, observer) => {\n      const rows = new Map();\n      entries.forEach(entry => {\n        if (entry.isIntersecting) {\n          const top = Math.round(entry.boundingClientRect.top);\n          let foundRow = false;\n          for (let [rowTop, items] of rows.entries()) {\n            if (Math.abs(rowTop - top) < 40) { // 40px tolerance for row alignment\n              items.push(entry.target);\n              foundRow = true;\n              break;\n            }\n          }\n          if (!foundRow) {\n            rows.set(top, [entry.target]);\n          }\n          observer.unobserve(entry.target);\n          \n          // Lazy play videos\n          const video = entry.target.querySelector('video');\n          if (video && video.hasAttribute('preload')) {\n             video.setAttribute('preload', 'auto');\n             video.play().catch(e => console.warn('Autoplay prevented:', e));\n          }\n        }\n      });\n      \n      if (rows.size > 0) {\n        const sortedRows = Array.from(rows.keys()).sort((a, b) => a - b);\n        sortedRows.forEach((rowTop, rowIndex) => {\n          const items = rows.get(rowTop);\n          items.forEach(item => {\n             // Delay based on row index to stagger downwards\n             item.style.transitionDelay = `${rowIndex * 0.15}s`;\n             requestAnimationFrame(() => {\n               item.style.opacity = '1';\n               item.style.transform = 'translateY(0)';\n             });\n          });\n        });\n      }\n    }, { rootMargin: '100px 0px', threshold: 0.05 });\n\n    // Handle loader logic (wait for first 6 items only to prevent long blank screens)\n    let loadedCount = 0;\n    const mediaToLoad = mediaElements.slice(0, 6);\n    const totalMedia = mediaToLoad.length;\n    const progressBar = document.getElementById('loader-progress-bar');\n    \n    const triggerAnimations = () => {\n      assetBoxes.forEach(box => animateObserver.observe(box));\n    };\n\n    const hideLoader = () => {\n      pageLoader.classList.add('is-hidden');\n      setTimeout(triggerAnimations, 100);\n    };\n\n    const updateProgress = () => {\n      if (progressBar) {\n        const percent = totalMedia > 0 ? (loadedCount / totalMedia) * 100 : 100;\n        progressBar.style.width = `${percent}%`;\n      }\n    };\n\n    if (totalMedia === 0) {\n      updateProgress();\n      setTimeout(hideLoader, 300);\n    } else {\n      let loaderDone = false;\n      const checkAllLoaded = () => {\n        if (loaderDone) return;\n        loadedCount++;\n        updateProgress();\n        if (loadedCount >= totalMedia) {\n          loaderDone = true;\n          setTimeout(hideLoader, 400);\n        }\n      };\n\n      mediaToLoad.forEach(media => {\n        if (media.tagName.toLowerCase() === 'img') {\n          if (media.complete) {\n            checkAllLoaded();\n          } else {\n            media.addEventListener('load', checkAllLoaded);\n            media.addEventListener('error', checkAllLoaded);\n          }\n        } else if (media.tagName.toLowerCase() === 'video') {\n          if (media.readyState >= 3) {\n            checkAllLoaded();\n          } else {\n            const handleVideoLoad = () => {\n              checkAllLoaded();\n              media.removeEventListener('canplay', handleVideoLoad);\n            };\n            media.addEventListener('canplay', handleVideoLoad);\n            media.addEventListener('error', checkAllLoaded);\n          }\n        }\n      });\n      \n      // Fallback timeout: 2.5 seconds max\n      setTimeout(() => {\n        if (!loaderDone) {\n          loaderDone = true;\n          hideLoader();\n        }\n      }, 2500);\n    }\n  }\n\n  // Work Page Filters\n  const filterBtns = document.querySelectorAll('.filter-btn');\n  const assetBoxesFilters = document.querySelectorAll('.page-work .asset-box');\n  if (filterBtns.length > 0 && assetBoxesFilters.length > 0) {\n    filterBtns.forEach(btn => {\n      btn.addEventListener('click', (e) => {\n        filterBtns.forEach(b => b.classList.remove('active'));\n        e.target.classList.add('active');\n\n        const filterValue = e.target.getAttribute('data-filter');\n        assetBoxesFilters.forEach(box => {\n          // Reset transition delay so hiding/showing isn't staggered weirdly\n          box.style.transitionDelay = '0s';\n          if (filterValue === 'all' || box.getAttribute('data-category') === filterValue) {\n            box.classList.remove('hidden');\n          } else {\n            box.classList.add('hidden');\n          }\n        });\n      });\n    });\n  }\n\n  // Brutalist Custom Cursor\n  const cursor = document.getElementById('custom-cursor');\n  if (cursor && window.matchMedia(\"(pointer: fine)\").matches) {\n    let mouseX = window.innerWidth / 2;\n    let mouseY = window.innerHeight / 2;\n    let cursorX = mouseX;\n    let cursorY = mouseY;\n\n    document.addEventListener('mousemove', (e) => {\n      mouseX = e.clientX;\n      mouseY = e.clientY;\n    });\n\n    const renderCursor = () => {\n      cursorX += (mouseX - cursorX) * 0.25;\n      cursorY += (mouseY - cursorY) * 0.25;\n      cursor.style.transform = `translate(calc(${cursorX}px - 50%), calc(${cursorY}px - 50%))`;\n      requestAnimationFrame(renderCursor);\n    };\n    requestAnimationFrame(renderCursor);\n\n    const interactables = document.querySelectorAll('a, button, .asset-box, input, textarea, .hover-trigger');\n    interactables.forEach(el => {\n      el.addEventListener('mouseenter', () => cursor.classList.add('hover'));\n      el.addEventListener('mouseleave', () => cursor.classList.remove('hover'));\n    });\n  }\n\n  // Parallax Effect via Object Position\n  const parallaxImages = document.querySelectorAll('.parallax-img');\n  let ticking = false;\n  \n  function updateParallax() {\n    parallaxImages.forEach(img => {\n      const rect = img.getBoundingClientRect();\n      if(rect.top < window.innerHeight && rect.bottom > 0) {\n         const yPos = (rect.top - window.innerHeight/2) * 0.04;\n         img.style.objectPosition = `50% calc(50% + ${yPos}px)`;\n      }\n    });\n    ticking = false;\n  }\n\n  if(parallaxImages.length > 0) {\n     updateParallax();\n     window.addEventListener('scroll', () => {\n       if (!ticking) {\n         window.requestAnimationFrame(updateParallax);\n         ticking = true;\n       }\n     }, { passive: true });\n  }\n\n  const contactForm = document.getElementById('contact-form');\n  const formMessages = document.getElementById('form-messages');\n\n  if (contactForm && formMessages) {\n    contactForm.addEventListener('submit', function(e) {\n      e.preventDefault();\n      \n      const submitBtn = contactForm.querySelector('button[type=\"submit\"]');\n      const originalBtnText = submitBtn.innerHTML;\n      submitBtn.innerHTML = 'SENDING...';\n      submitBtn.disabled = true;\n\n      const formData = new FormData(contactForm);\n      const data = Object.fromEntries(formData.entries());\n\n      fetch(contactForm.action, {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json',\n          'Accept': 'application/json'\n        },\n        body: JSON.stringify(data)\n      })\n      .then(response => response.json())\n      .then(data => {\n        if (data.success || data.success === \"true\") {\n          contactForm.reset();\n          formMessages.innerHTML = 'Message sent successfully. I will get back to you soon.';\n          formMessages.style.color = \"var(--text-primary)\";\n        } else {\n          formMessages.innerHTML = data.message || 'Oops! There was a problem submitting your form.';\n          formMessages.style.color = \"var(--accent-color)\";\n        }\n      })\n      .catch(error => {\n        formMessages.innerHTML = 'Oops! There was a problem submitting your form.';\n        formMessages.style.color = \"var(--accent-color)\";\n      })\n      .finally(() => {\n        submitBtn.innerHTML = originalBtnText;\n        submitBtn.disabled = false;\n        setTimeout(() => {\n          formMessages.innerHTML = '';\n          formMessages.style.color = \"\";\n        }, 5000);\n      });\n    });\n  }\n  \n  // Back to Top Button Logic\n  const backToTop = document.getElementById('back-to-top');\n  if (backToTop) {\n    window.addEventListener('scroll', () => {\n      if (window.scrollY > 500) {\n        backToTop.classList.add('is-visible');\n      } else {\n        backToTop.classList.remove('is-visible');\n      }\n    }, { passive: true });\n\n    backToTop.addEventListener('click', () => {\n      window.scrollTo({\n        top: 0,\n        behavior: 'smooth'\n      });\n    });\n  }\n});"},"assets":[{"id":"1774738660376","name":"Veega Instagram Ad","url":"asset://1774738660376","type":"animation","year":"2023","description":"","isTemporary":false,"category":"General","repoPath":"assets/1774738660376-Veega Instagram Ad","dataUrl":"blob:https://ais-dev-7mtnyci3lbcvs54ocpn3hq-644473134194.asia-east1.run.app/4e487e82-ffbc-4ee7-b90f-7dab5d633d9e"},{"id":"1774738684886","name":"MGMA Wrap Up","url":"asset://1774738684886","type":"video","year":"2025","description":"","isTemporary":false,"category":"General","repoPath":"assets/1774738684886-MGMA Wrap Up","dataUrl":"blob:https://ais-dev-7mtnyci3lbcvs54ocpn3hq-644473134194.asia-east1.run.app/4ffafea5-d4d3-40cb-88b5-837b260f0192"},{"id":"1774738706550","name":"Becker's Event Announcement","url":"asset://1774738706550","type":"image","year":"2026","description":"","isTemporary":false,"category":"General","repoPath":"assets/1774738706550-Becker's Event Announcement","dataUrl":"blob:https://ais-dev-7mtnyci3lbcvs54ocpn3hq-644473134194.asia-east1.run.app/2f886434-b3fb-42c7-aa4a-0ad178a70d1d"},{"id":"1774739075614","name":"PF Crispy Fried Chicken Ads Father's Day","url":"asset://1774739075614","type":"image","year":"2023","description":"","isTemporary":false,"category":"General","repoPath":"assets/1774739075614-PF Crispy Fried Chicken Ads Father's Day","dataUrl":"blob:https://ais-dev-7mtnyci3lbcvs54ocpn3hq-644473134194.asia-east1.run.app/acf3a191-a650-4f56-a4af-42c6c84b22fc"},{"id":"1774739118170","name":"Courts Father's