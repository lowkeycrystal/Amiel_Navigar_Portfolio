iv><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://dcnxrqkib\" alt=\"Interactive Book Cover 1\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://xb32l5xle\" alt=\"Interactive Book Cover 2\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://ee6jtn39s\" alt=\"Interactive Book Cover 3\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"project-details fade-in-up\">\n    <div class=\"container split-layout\">\n      <div class=\"split-text\">\n        <h2 class=\"section-title\">The Challenge</h2>\n        <p class=\"text-muted\">Stripping away the excess to reveal the core message within a crowded digital landscape. The objective was to prioritize raw function over decorative polish to capture attention quickly and cleanly on social feeds.</p>\n      </div>\n      <div class=\"split-text\">\n        <h2 class=\"section-title\">The Execution</h2>\n        <p class=\"text-muted\">Utilizing stark contrasts and unyielding grids to frame the asset. Imperfections in texture are embraced, allowing the inherent visual qualities of the media to speak for themselves, unfiltered and honest.</p>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"next-project-nav mt-4\">\n    <div class=\"container text-center\">\n      <p class=\"label\">[CONTINUE]</p>\n      <a href=\"work.html\" class=\"mega-title hover-accent\">Next Project <svg width=\"40\" height=\"40\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1\"><path d=\"M5 12h14M12 5l7 7-7\"/></svg></a>\n    </div>\n  </section>\n</main>\n\n<footer class=\"site-footer\">\n  <div class=\"container\">\n    <div class=\"footer-grid\">\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">MULTIMEDIA DESIGNER</h4>\n        <p class=\"text-muted\">Embracing imperfection.<br>Finding beauty in the raw.</p>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">NAVIGATION</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"index.html\">Home</a></li>\n          <li><a href=\"work.html\">Work</a></li>\n          <li><a href=\"about.html\">About</a></li>\n          <li><a href=\"contact.html\">Contact</a></li>\n        </ul>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">CONNECT</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"https://www.linkedin.com/in/amielnavigar/\" target=\"_blank\" rel=\"noopener noreferrer\">LinkedIn</a></li>\n        </ul>\n      </div>\n    </div>\n    <div class=\"footer-bottom\">\n      <div class=\"copyright\">© 2026</div>\n      <div class=\"quote\">Nothing is permanent.</div>\n    </div>\n  </div>\n</footer>\n\n<div id=\"custom-cursor\" class=\"custom-cursor\"></div>\n<script src=\"script.js\"></script>"},{"name":"project-almorjan.html","html":"<link rel=\"stylesheet\" href=\"style.css\">\n<div class=\"page-transition\"></div>\n<header id=\"main-header\">\n  <div class=\"container header-inner\">\n    <a href=\"index.html\" class=\"logo\">AMIEL NAVIGAR</a>\n    <nav>\n      <ul class=\"nav-links\">\n        <li><a href=\"index.html\">HOME</a></li>\n        <li><a href=\"work.html\" class=\"active\">WORK</a></li>\n        <li><a href=\"about.html\">ABOUT</a></li>\n        <li><a href=\"contact.html\">CONTACT</a></li>\n        <li>\n          <button id=\"theme-toggle\" class=\"theme-toggle\" aria-label=\"Toggle Theme\">\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"currentColor\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 2v20a10 10 0 1 0 0-20z\"/></svg>\n          </button>\n        </li>\n      </ul>\n    </nav>\n  </div>\n</header>\n\n<main class=\"page-project\">\n  <section class=\"project-hero fade-in-up\">\n    <div class=\"container\">\n      <a href=\"work.html\" class=\"link-btn mb-4\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M19 12H5M12 19l-7-7 7-7\"/></svg> BACK TO WORK</a>\n      \n      <div class=\"label\">[CASE STUDY]</div>\n      <h1 class=\"mega-title\">Al-Morjan Park<br>Feed</h1>\n      \n      <div class=\"project-meta mt-3\">\n        <div class=\"meta-item\">\n          <span class=\"label\">CLIENT</span>\n          <p>Al-Morjan Park</p>\n        </div>\n        <div class=\"meta-item\">\n          <span class=\"label\">ROLE</span>\n          <p>Production, Graphic Design</p>\n        </div>\n        <div class=\"meta-item\">\n          <span class=\"label\">YEAR</span>\n          <p>2025</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"project-media fade-in-up\">\n    <div class=\"container\">\n      <div class=\"media-gallery-grid\">\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://9fp6qgzp5\" alt=\"Al-Morjan Park Feed 1\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://v8gk1rj9k\" alt=\"Al-Morjan Park Feed 2\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"project-details fade-in-up\">\n    <div class=\"container split-layout\">\n      <div class=\"split-text\">\n        <h2 class=\"section-title\">The Challenge</h2>\n        <p class=\"text-muted\">Stripping away the excess to reveal the core message within a crowded digital landscape. The objective was to prioritize raw function over decorative polish to capture attention quickly and cleanly on social feeds.</p>\n      </div>\n      <div class=\"split-text\">\n        <h2 class=\"section-title\">The Execution</h2>\n        <p class=\"text-muted\">Utilizing stark contrasts and unyielding grids to frame the asset. Imperfections in texture are embraced, allowing the inherent visual qualities of the media to speak for themselves, unfiltered and honest.</p>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"next-project-nav mt-4\">\n    <div class=\"container text-center\">\n      <p class=\"label\">[CONTINUE]</p>\n      <a href=\"work.html\" class=\"mega-title hover-accent\">Next Project <svg width=\"40\" height=\"40\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1\"><path d=\"M5 12h14M12 5l7 7-7\"/></svg></a>\n    </div>\n  </section>\n</main>\n\n<footer class=\"site-footer\">\n  <div class=\"container\">\n    <div class=\"footer-grid\">\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">MULTIMEDIA DESIGNER</h4>\n        <p class=\"text-muted\">Embracing imperfection.<br>Finding beauty in the raw.</p>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">NAVIGATION</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"index.html\">Home</a></li>\n          <li><a href=\"work.html\">Work</a></li>\n          <li><a href=\"about.html\">About</a></li>\n          <li><a href=\"contact.html\">Contact</a></li>\n        </ul>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">CONNECT</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"https://www.linkedin.com/in/amielnavigar/\" target=\"_blank\" rel=\"noopener noreferrer\">LinkedIn</a></li>\n        </ul>\n      </div>\n    </div>\n    <div class=\"footer-bottom\">\n      <div class=\"copyright\">© 2026</div>\n      <div class=\"quote\">Nothing is permanent.</div>\n    </div>\n  </div>\n</footer>\n\n<div id=\"custom-cursor\" class=\"custom-cursor\"></div>\n<script src=\"script.js\"></script>"}],"css":"@import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@400;500&family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap');\n\n/* Theme Variables - High Contrast Brutalist Light/Dark Mode */\n:root, [data-theme=\"dark\"], body[data-theme=\"dark\"] {\n  /* Dark Mode (Default) */\n  --bg-color: #161616;\n  --surface-color: #1a1a1a;\n  --text-primary: #f0f0f0;\n  --text-muted: #888888;\n  --accent-color: #d65a31;\n  --border-color: #333333;\n  --grid-opacity: 0.02;\n  --glass-bg: rgba(22, 22, 22, 0.7);\n  \n  --font-serif: 'DM Serif Display', Georgia, serif;\n  --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n  --font-mono: 'Space Mono', 'Courier New', Courier, monospace;\n}\n\n:root[data-theme=\"light\"], [data-theme=\"light\"], body[data-theme=\"light\"] {\n  /* Light Mode (High Contrast Paper/Ink) */\n  --bg-color: #f4f4f0;\n  --surface-color: #e8e8e4;\n  --text-primary: #0a0a0a;\n  --text-muted: #555555;\n  --accent-color: #ff3300;\n  --border-color: #c0c0bc;\n  --grid-opacity: 0.06;\n  --glass-bg: rgba(244, 244, 240, 0.8);\n}\n\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nbody {\n  background-color: var(--bg-color);\n  color: var(--text-primary);\n  font-family: var(--font-sans);\n  line-height: 1.6;\n  overflow-x: hidden;\n  transition: background-color 0.3s ease, color 0.3s ease;\n}\n\nimg, svg, video {\n  max-width: 100%;\n  display: block;\n}\n\na {\n  color: inherit;\n  text-decoration: none;\n  transition: color 0.3s ease;\n}\n\nul {\n  list-style: none;\n}\n\n/* Page Transitions (Subtle Wipe) */\n.page-transition {\n  position: fixed;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100vh;\n  background-color: var(--surface-color);\n  z-index: 999999;\n  pointer-events: none;\n  transform-origin: top;\n  transform: scaleY(1);\n  transition: transform 0.6s cubic-bezier(0.85, 0, 0.15, 1);\n}\n\n.page-transition.is-loaded {\n  transform: scaleY(0);\n  transform-origin: bottom;\n}\n\n.page-transition.is-leaving {\n  transform: scaleY(1);\n  transform-origin: top;\n}\n\n/* Custom Cursor */\n@media (pointer: fine) {\n  body, a, button, .asset-box, input, textarea {\n    cursor: none;\n  }\n}\n\n.custom-cursor {\n  position: fixed;\n  top: 0;\n  left: 0;\n  width: 12px;\n  height: 12px;\n  background-color: var(--accent-color);\n  transform: translate(-50%, -50%);\n  pointer-events: none;\n  z-index: 99999;\n  transition: background-color 0.2s, width 0.2s, height 0.2s, border-radius 0.2s, border 0.2s;\n  mix-blend-mode: difference;\n}\n\n.custom-cursor.hover {\n  width: 48px;\n  height: 48px;\n  background-color: transparent;\n  border: 1.5px solid var(--accent-color);\n  border-radius: 50%;\n}\n\n@media (pointer: coarse) {\n  .custom-cursor {\n    display: none !important;\n  }\n}\n\n/* Typography */\nh1, h2, h3, h4 {\n  font-family: var(--font-serif);\n  font-weight: 400;\n  line-height: 1.1;\n}\n\n.label {\n  font-family: var(--font-mono);\n  color: var(--accent-color);\n  font-size: 0.75rem;\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n  margin-bottom: 1rem;\n}\n\n.accent-italic {\n  color: var(--accent-color);\n  font-style: italic;\n}\n\n.text-muted {\n  color: var(--text-muted);\n  transition: color 0.3s ease;\n}\n\n.mono-text {\n  font-family: var(--font-mono);\n  font-size: 0.85rem;\n}\n\n.text-sm {\n  font-size: 0.9rem;\n}\n\n.mt-1 { margin-top: 1rem; }\n.mt-2 { margin-top: 2rem; }\n.mt-3 { margin-top: 3rem; }\n.mt-4 { margin-top: 5rem; }\n.mb-1 { margin-bottom: 0.5rem; }\n.mb-4 { margin-bottom: 5rem; }\n.text-center { text-align: center; }\n.align-right { text-align: right; }\n.max-w-sm { max-width: 450px; }\n\n/* Utility Classes */\n.hidden {\n  display: none !important;\n}\n\n.hover-accent:hover {\n  color: var(--accent-color);\n}\n\n/* Layout */\n.container {\n  width: 90%;\n  max-width: 1280px;\n  margin: 0 auto;\n}\n\nmain {\n  padding-top: 120px;\n  min-height: calc(100vh - 200px);\n}\n\nsection {\n  padding: 4rem 0;\n}\n\n/* Header & Theme Toggle */\n#main-header {\n  position: fixed;\n  top: 0;\n  left: 0;\n  width: 100%;\n  z-index: 1000;\n  padding: 1.5rem 0;\n  transition: all 0.4s ease;\n  border-bottom: 1px solid transparent;\n}\n\n#main-header.scrolled {\n  background: var(--glass-bg);\n  backdrop-filter: blur(12px);\n  -webkit-backdrop-filter: blur(12px);\n  border-bottom: 1px solid var(--border-color);\n  padding: 1rem 0;\n}\n\n.header-inner {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.logo {\n  font-family: var(--font-mono);\n  font-weight: bold;\n  letter-spacing: 0.1em;\n  font-size: 0.9rem;\n}\n\n.nav-links {\n  display: flex;\n  gap: 2rem;\n  align-items: center;\n  font-family: var(--font-mono);\n  font-size: 0.75rem;\n  letter-spacing: 0.05em;\n}\n\n.nav-links a:hover {\n  color: var(--accent-color);\n}\n\n.nav-links a.active {\n  color: var(--accent-color);\n}\n\n.theme-toggle {\n  background: none;\n  border: 1px solid var(--border-color);\n  color: var(--text-primary);\n  border-radius: 50%;\n  width: 30px;\n  height: 30px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  cursor: pointer;\n  transition: all 0.3s ease;\n}\n.theme-toggle:hover {\n  border-color: var(--accent-color);\n  color: var(--accent-color);\n}\n\n/* Marquee (Brutalist Banner) */\n.marquee {\n  width: 100%;\n  overflow: hidden;\n  background: var(--text-primary);\n  color: var(--bg-color);\n  padding: 1rem 0;\n  border-top: 1px solid var(--border-color);\n  border-bottom: 1px solid var(--border-color);\n  display: flex;\n  white-space: nowrap;\n  transition: background-color 0.3s ease, color 0.3s ease;\n}\n.marquee-content {\n  display: flex;\n  animation: marquee-scroll 25s linear infinite;\n}\n.marquee-text {\n  font-family: var(--font-mono);\n  font-size: 1.2rem;\n  font-weight: 700;\n  text-transform: uppercase;\n  padding: 0 1rem;\n  letter-spacing: 0.05em;\n}\n@keyframes marquee-scroll {\n  0% { transform: translateX(0); }\n  100% { transform: translateX(-50%); }\n}\n\n/* Buttons & Links */\n.link-btn {\n  display: inline-flex;\n  align-items: center;\n  gap: 0.5rem;\n  font-family: var(--font-mono);\n  font-size: 0.8rem;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  border-bottom: 1px solid transparent;\n  padding-bottom: 0.2rem;\n  transition: border-color 0.3s ease;\n}\n\n.link-btn:hover {\n  border-color: var(--text-primary);\n}\n\n.btn-outline {\n  display: inline-flex;\n  align-items: center;\n  gap: 0.5rem;\n  font-family: var(--font-mono);\n  font-size: 0.8rem;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  border: 1px solid var(--border-color);\n  padding: 1rem 2rem;\n  background: transparent;\n  color: var(--text-primary);\n  cursor: pointer;\n  transition: all 0.3s ease;\n}\n\n.btn-outline:hover {\n  border-color: var(--text-primary);\n  background: var(--text-primary);\n  color: var(--bg-color);\n}\n\n/* Asset Box (Links to Case Study) */\n.asset-box {\n  display: block;\n  position: relative;\n  background-color: var(--surface-color);\n  border: 1px solid rgba(214, 90, 49, 0.4); \n  aspect-ratio: 16/9;\n  overflow: hidden;\n  background-image: \n    linear-gradient(rgba(150,150,150, var(--grid-opacity)) 1px, transparent 1px),\n    linear-gradient(90deg, rgba(150,150,150, var(--grid-opacity)) 1px, transparent 1px);\n  background-size: 30px 30px;\n  transition: border-color 0.3s ease, background-color 0.3s ease;\n}\n\n.asset-box:hover {\n  border-color: var(--accent-color);\n}\n\n.asset-media {\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  z-index: 1;\n  pointer-events: none; \n}\n\n/* Corner brackets */\n.corner {\n  position: absolute;\n  width: 15px;\n  height: 15px;\n  border-color: rgba(214, 90, 49, 0.4);\n  border-style: solid;\n  border-width: 0;\n  z-index: 2;\n  transition: border-color 0.3s ease;\n}\n.asset-box:hover .corner { border-color: var(--accent-color); }\n\n.corner-tl { top: 1.5rem; left: 1.5rem; border-top-width: 1px; border-left-width: 1px; }\n.corner-tr { top: 1.5rem; right: 1.5rem; border-top-width: 1px; border-right-width: 1px; }\n.corner-bl { bottom: 1.5rem; left: 1.5rem; border-bottom-width: 1px; border-left-width: 1px; }\n.corner-br { bottom: 1.5rem; right: 1.5rem; border-bottom-width: 1px; border-right-width: 1px; }\n\n/* Center Crosshair */\n.crosshair {\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  width: 20px;\n  height: 20px;\n  z-index: 2;\n}\n.crosshair::before, .crosshair::after {\n  content: '';\n  position: absolute;\n  background-color: rgba(214, 90, 49, 0.4);\n  transition: background-color 0.3s ease;\n}\n.asset-box:hover .crosshair::before, \n.asset-box:hover .crosshair::after {\n  background-color: var(--accent-color);\n}\n.crosshair::before { top: 50%; left: 0; width: 100%; height: 1px; }\n.crosshair::after { left: 50%; top: 0; height: 100%; width: 1px; }\n\n/* Project Hover Info */\n.project-hover {\n  position: absolute;\n  inset: 0;\n  background: rgba(22, 22, 22, 0.85);\n  backdrop-filter: blur(2px);\n  display: flex;\n  flex-direction: column;\n  justify-content: flex-end;\n  padding: 2rem;\n  opacity: 0;\n  transition: opacity 0.4s ease, transform 0.4s ease;\n  transform: translateY(10px);\n  z-index: 10;\n  color: #f0f0f0;\n}\n\n.asset-box:hover .project-hover {\n  opacity: 1;\n  transform: translateY(0);\n}\n\n.project-title {\n  font-family: var(--font-mono);\n  font-size: 1.1rem;\n  font-weight: 700;\n  margin-bottom: 0.5rem;\n  letter-spacing: 0.05em;\n}\n\n.project-year {\n  font-family: var(--font-mono);\n  font-size: 0.75rem;\n  color: #aaa;\n  text-transform: uppercase;\n}\n\n/* --- PAGE SPECIFIC STYLES --- */\n\n/* Index Page */\n.hero {\n  min-height: 70vh;\n  display: flex;\n  align-items: center;\n}\n.hero-title {\n  font-size: clamp(4rem, 8vw, 7rem);\n  margin-bottom: 2rem;\n}\n.hero-sub {\n  max-width: 500px;\n  color: var(--text-muted);\n  font-size: 1.1rem;\n}\n.hero-sub p { margin-bottom: 1.5rem; }\n\n.section-title {\n  font-size: 2.5rem;\n  margin-bottom: 3rem;\n}\n\n/* Bento Grid for Projects */\n.bento-grid {\n  display: grid;\n  grid-template-columns: 1fr;\n  gap: 2rem;\n}\n@media (min-width: 768px) {\n  .bento-grid {\n    grid-template-columns: repeat(6, 1fr);\n  }\n  .span-3 { grid-column: span 3; }\n  .span-2 { grid-column: span 2; }\n  .span-full { grid-column: 1 / -1; }\n}\n\n/* Split Layouts */\n.split-layout {\n  display: grid;\n  grid-template-columns: 1fr;\n  gap: 4rem;\n}\n@media (min-width: 900px) {\n  .split-layout {\n    grid-template-columns: 1fr 1fr;\n  }\n  .align-center { align-items: center; }\n}\n\n.large-heading {\n  font-size: clamp(2.5rem, 5vw, 4rem);\n}\n\n/* Aspect Ratio Helpers */\n.box-tall { aspect-ratio: 3/4; }\n.box-square { aspect-ratio: 1/1; }\n.box-4-5 { aspect-ratio: 4/5; }\n.box-21-9 { aspect-ratio: 21/9; }\n@media (min-width: 768px) {\n  .box-21-9 { aspect-ratio: 3/1; }\n}\n\n/* Capabilities Grid */\n.grid-4 {\n  display: grid;\n  grid-template-columns: 1fr;\n  gap: 2rem;\n  border-top: 1px solid var(--border-color);\n  padding-top: 3rem;\n}\n@media (min-width: 600px) { .grid-4 { grid-template-columns: repeat(2, 1fr); } }\n@media (min-width: 900px) { .grid-4 { grid-template-columns: repeat(4, 1fr); } }\n\n.capability-item .cap-num { color: var(--accent-color); margin-bottom: 1rem; }\n.capability-item .cap-title {\n  font-size: 1.5rem;\n  font-family: var(--font-serif);\n  font-weight: 400;\n  margin-bottom: 0.5rem;\n}\n\n.mega-title { font-size: clamp(3rem, 6vw, 5rem); }\n\n/* Project Template Page Specifics */\n.project-meta {\n  display: flex;\n  gap: 3rem;\n  border-top: 1px solid var(--border-color);\n  padding-top: 1.5rem;\n  flex-wrap: wrap;\n}\n.meta-item p {\n  font-family: var(--font-sans);\n  font-weight: 500;\n  font-size: 1.1rem;\n}\n\n/* Media Showcase for Project Pages */\n.media-showcase {\n  position: relative;\n  background-color: var(--surface-color);\n  border: 1px solid rgba(214, 90, 49, 0.4); \n  padding: 2rem;\n  background-image: \n    linear-gradient(rgba(150,150,150, var(--grid-opacity)) 1px, transparent 1px),\n    linear-gradient(90deg, rgba(150,150,150, var(--grid-opacity)) 1px, transparent 1px);\n  background-size: 30px 30px;\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  transition: border-color 0.3s ease;\n}\n.media-showcase:hover {\n  border-color: var(--accent-color);\n}\n.media-showcase .corner {\n  border-color: rgba(214, 90, 49, 0.4);\n}\n.media-showcase:hover .corner {\n  border-color: var(--accent-color);\n}\n.media-showcase-inner {\n  position: relative;\n  z-index: 1;\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  width: 100%;\n  height: 100%;\n}\n.asset-media-contain {\n  max-width: 100%;\n  max-height: 70vh;\n  object-fit: contain;\n}\n\n/* Media Gallery Grid for Multi-Asset Projects */\n.media-gallery-grid {\n  display: grid;\n  grid-template-columns: 1fr;\n  gap: 2rem;\n}\n@media (min-width: 768px) {\n  .media-gallery-grid {\n    grid-template-columns: repeat(2, 1fr);\n  }\n}\n\n/* Work Page */\n.page-title { font-size: clamp(3rem, 6vw, 5rem); }\n.filter-bar {\n  display: flex;\n  gap: 2rem;\n  border-bottom: 1px solid var(--border-color);\n  padding-bottom: 1rem;\n  overflow-x: auto;\n}\n.filter-btn {\n  background: none;\n  border: none;\n  color: var(--text-muted);\n  font-family: var(--font-mono);\n  font-size: 0.75rem;\n  cursor: pointer;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  transition: color 0.3s ease;\n  white-space: nowrap;\n}\n.filter-btn:hover, .filter-btn.active {\n  color: var(--accent-color);\n}\n\n.gallery-grid {\n  display: grid;\n  grid-template-columns: 1fr;\n  gap: 2rem;\n}\n@media (min-width: 600px) { .gallery-grid { grid-template-columns: repeat(2, 1fr); } }\n@media (min-width: 1024px) { .gallery-grid { grid-template-columns: repeat(3, 1fr); } }\n\n/* About Page */\n.bio-text p { margin-bottom: 1.5rem; }\n.box-portrait { aspect-ratio: 3/4; max-width: 500px; margin: 0 auto; }\n\n.exp-list { border-top: 1px solid var(--border-color); }\n.exp-item {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 2rem 0;\n  border-bottom: 1px solid var(--border-color); }\n.exp-role { font-weight: 500; font-family: var(--font-sans); }\n.exp-date { margin-bottom: 0; }\n\n.tags-container { display: flex; flex-wrap: wrap; gap: 0.5rem; }\n.tag {\n  display: inline-block;\n  border: 1px solid var(--border-color);\n  padding: 0.4rem 0.8rem;\n  font-family: var(--font-mono);\n  font-size: 0.7rem;\n  color: var(--text-muted);\n  transition: border-color 0.3s ease, color 0.3s ease, background-color 0.3s ease;\n}\n.tag:hover {\n  border-color: var(--text-primary);\n  color: var(--bg-color);\n  background-color: var(--text-primary);\n}\n\n.grid-3 {\n  display: grid;\n  grid-template-columns: 1fr;\n  gap: 2rem;\n}\n@media (min-width: 768px) { .grid-3 { grid-template-columns: repeat(3, 1fr); } }\n.info-card {\n  border: 1px solid var(--border-color);\n  padding: 2rem;\n  background: var(--surface-color);\n  transition: border-color 0.3s ease, background-color 0.3s ease;\n}\n.card-title {\n  font-family: var(--font-serif);\n  font-size: 1.5rem;\n  font-weight: 400;\n  margin-bottom: 1rem;\n}\n\n/* Added for Experience Detail Section */\n.exp-item-detailed {\n  flex-direction: column;\n  align-items: flex-start;\n}\n.exp-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  width: 100%;\n}\n.exp-details {\n  max-width: 800px;\n}\n.bullet-list {\n  list-style-type: square;\n  padding-left: 1.5rem;\n  margin-top: 0.5rem;\n}\n.bullet-list li {\n  margin-bottom: 0.5rem;\n}\n\n/* Contact Page */\n.split-layout-contact {\n  display: grid;\n  grid-template-columns: 1fr;\n  gap: 4rem;\n}\n@media (min-width: 900px) {\n  .split-layout-contact {\n    grid-template-columns: 1fr 1fr;\n  }\n}\n\n.contact-item {\n  display: flex;\n  align-items: center;\n  gap: 1rem;\n}\n.contact-item .label { margin-bottom: 0; }\n\n.contact-form .form-group { margin-bottom: 2rem; }\n.contact-form input, .contact-form textarea {\n  width: 100%;\n  background: transparent;\n  border: none;\n  border-bottom: 1px solid var(--border-color);\n  padding: 0.5rem 0 1rem 0;\n  color: var(--text-primary);\n  font-family: var(--font-sans);\n  font-size: 1rem;\n  transition: border-color 0.3s ease;\n  resize: none;\n}\n.contact-form input:focus, .contact-form textarea:focus {\n  outline: none;\n  border-color: var(--accent-color);\n}\n.contact-form input::placeholder, .contact-form textarea::placeholder {\n  color: var(--text-muted);\n}\n\n/* Footer */\n.site-footer {\n  border-top: 1px solid var(--border-color);\n  padding: 4rem 0 2rem 0;\n  margin-top: 4rem;\n}\n.footer-grid {\n  display: grid;\n  grid-template-columns: 1fr;\n  gap: 3rem;\n  margin-bottom: 4rem;\n}\n@media (min-width: 600px) { .footer-grid { grid-template-columns: repeat(2, 1fr); } }\n@media (min-width: 900px) { .footer-grid { grid-template-columns: 2fr 1fr 1fr; } }\n\n.footer-heading {\n  font-family: var(--font-mono);\n  font-size: 0.75rem;\n  color: var(--text-muted);\n  margin-bottom: 1.5rem;\n  letter-spacing: 0.1em;\n}\n.footer-links li { margin-bottom: 0.5rem; }\n.footer-links a {\n  font-family: var(--font-mono);\n  font-size: 0.85rem;\n  color: var(--text-muted);\n}\n.footer-links a:hover { color: var(--text-primary); }\n\n.footer-bottom {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  border-top: 1px solid var(--border-color);\n  padding-top: 2rem;\n  font-family: var(--font-mono);\n  font-size: 0.75rem;\n  color: var(--text-muted);\n}\n\n/* Animations */\n.fade-in-up {\n  opacity: 0;\n  transform: translateY(30px);\n  transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);\n}\n.fade-in-up.is-visible {\n  opacity: 1;\n  transform: translateY(0);\n}","js":"function getSafeTheme() {\n  try {\n    return localStorage.getItem('theme') || 'dark';\n  } catch (error) {\n    console.warn('localStorage is unavailable, falling back to dark mode.');\n    return 'dark';\n  }\n}\n\nfunction setSafeTheme(theme) {\n  try {\n    localStorage.setItem('theme', theme);\n  } catch (error) {\n    console.warn('localStorage is unavailable, could not save theme preference.');\n  }\n}\n\n// Apply theme immediately to prevent FOUC\nconst currentTheme = getSafeTheme();\ndocument.documentElement.setAttribute('data-theme', currentTheme);\n\ndocument.addEventListener('DOMContentLoaded', () => {\n  // 1. Theme Toggle Logic (High Contrast Light/Dark Mode) with fallback\n  const themeBtn = document.getElementById('theme-toggle');\n  \n  if (document.body) {\n    document.body.setAttribute('data-theme', currentTheme);\n  }\n\n  if (themeBtn) {\n    themeBtn.addEventListener('click', (e) => {\n      e.preventDefault();\n      const existingTheme = document.documentElement.getAttribute('data-theme') || 'dark';\n      const newTheme = existingTheme === 'dark' ? 'light' : 'dark';\n      \n      document.documentElement.setAttribute('data-theme', newTheme);\n      if (document.body) {\n        document.body.setAttribute('data-theme', newTheme);\n      }\n      setSafeTheme(newTheme);\n    });\n  }\n\n  // 2. Page Transition Logic\n  const transitionEl = document.querySelector('.page-transition');\n  if (transitionEl) {\n    // Animate out on load\n    setTimeout(() => {\n      transitionEl.classList.add('is-loaded');\n    }, 150);\n  }\n\n  // 3. Glassmorphism Header on Scroll\n  const header = document.getElementById('main-header');\n  const handleScroll = () => {\n    if (window.scrollY > 50) {\n      header.classList.add('scrolled');\n    } else {\n      header.classList.remove('scrolled');\n    }  \n  };\n  window.addEventListener('scroll', handleScroll, { passive: true });\n  handleScroll();\n\n  // 4. Intersection Observer for subtle scroll animations\n  const observerOptions = {\n    root: null,\n    rootMargin: '0px',\n    threshold: 0.15\n  };\n  const observer = new IntersectionObserver((entries, observer) => {\n    entries.forEach(entry => {\n      if (entry.isIntersecting) {\n        entry.target.classList.add('is-visible');\n        observer.unobserve(entry.target);\n      }\n    });\n  }, observerOptions);\n  const animatedElements = document.querySelectorAll('.fade-in-up');\n  animatedElements.forEach(el => observer.observe(el));\n\n  // 5. Functional Filtering for Work Page\n  const filterBtns = document.querySelectorAll('.filter-btn');\n  const assetBoxes = document.querySelectorAll('.page-work .asset-box');\n  if (filterBtns.length > 0 && assetBoxes.length > 0) {\n    filterBtns.forEach(btn => {\n      btn.addEventListener('click', (e) => {\n        filterBtns.forEach(b => b.classList.remove('active'));\n        e.target.classList.add('active');\n        \n        const filterValue = e.target.getAttribute('data-filter');\n        assetBoxes.forEach(box => {\n          if (filterValue === 'all' || box.getAttribute('data-category') === filterValue) {\n            box.classList.remove('hidden');\n          } else {\n            box.classList.add('hidden');\n          }\n        });\n      });\n    });\n  }\n\n  // 6. Custom Brutalist Cursor Logic\n  const cursor = document.getElementById('custom-cursor');\n  if (cursor && window.matchMedia(\"(pointer: fine)\").matches) {\n    let mouseX = window.innerWidth / 2;\n    let mouseY = window.innerHeight / 2;\n    let cursorX = mouseX;\n    let cursorY = mouseY;\n\n    document.addEventListener('mousemove', (e) => {\n      mouseX = e.clientX;\n      mouseY = e.clientY;\n    });\n\n    const renderCursor = () => {\n      cursorX += (mouseX - cursorX) * 0.25;\n      cursorY += (mouseY - cursorY) * 0.25;\n      cursor.style.transform = `translate(calc(${cursorX}px - 50%), calc(${cursorY}px - 50%))`;\n      requestAnimationFrame(renderCursor);\n    };\n    requestAnimationFrame(renderCursor);\n\n    const interactables = document.querySelectorAll('a, button, .asset-box, input, textarea');\n    interactables.forEach(el => {\n      el.addEventListener('mouseenter', () => cursor.classList.add('hover'));\n      el.addEventListener('mouseleave', () => cursor.classList.remove('hover'));\n    });\n  }\n});"},"assets":[{"id":"1774738660376","name":"Veega Instagram Ad","url":"asset://1774738660376","type":"animation","year":"2023","description":"","isTemporary":false,"category":"General","repoPath":"assets/1774738660376-Veega Instagram Ad"},{"id":"1774738684886","name":"MGMA Wrap Up","url":"asset://1774738684886","type":"video","year":"2025","description":"","isTemporary":false,"category":"General","repoPath":"assets/1774738684886-MGMA Wrap Up"},{"id":"1774738706550","name":"Becker's Event Announcement","url":"asset://1774738706550","type":"image","year":"2026","description":"","i