n class=\"label\">CLIENT</span>\n          <p>Samsung</p>\n        </div>\n        <div class=\"meta-item\">\n          <span class=\"label\">ROLE</span>\n          <p>Graphic Design</p>\n        </div>\n        <div class=\"meta-item\">\n          <span class=\"label\">YEAR</span>\n          <p>2023</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"project-media fade-in-up\">\n    <div class=\"container\">\n      <div class=\"media-gallery-grid\">\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://o6s4kgm2s\" alt=\"Samsung Product Ad Cover\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://73t4w654s\" alt=\"Samsung Product Ad Frame 1\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"media-showcase-inner\">\n            <img src=\"asset://ps5h1dlce\" alt=\"Samsung Product Ad Frame 2\" class=\"asset-media-contain\" referrerPolicy=\"no-referrer\">\n          </div>\n        </div>\n        <div class=\"media-showcase\" style=\"cursor: default;\">\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><