{"site":{"pages":[{"name":"about.html","html":"<title>About - Amiel Navigar | Multimedia Designer</title>\n<link rel=\"stylesheet\" href=\"style.css\">\n<div class=\"page-transition\"></div>\n<header id=\"main-header\">\n  <div class=\"container header-inner\">\n    <a href=\"index.html\" class=\"logo\">AMIEL NAVIGAR</a>\n    <nav>\n      <ul class=\"nav-links\">\n        <li><a href=\"index.html\">HOME</a></li>\n        <li><a href=\"work.html\">WORK</a></li>\n        <li><a href=\"about.html\" class=\"active\">ABOUT</a></li>\n        <li><a href=\"contact.html\">CONTACT</a></li>\n        <li>\n          <button id=\"theme-toggle\" class=\"theme-toggle\" aria-label=\"Toggle Theme\">\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"currentColor\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 2v20a10 10 0 1 0 0-20z\"/></svg>\n          </button>\n        </li>\n      </ul>\n    </nav>\n  </div>\n</header>\n\n<main class=\"page-about\">\n  <section class=\"about-hero fade-in-up\">\n    <div class=\"container split-layout\">\n      <div class=\"split-text\">\n        <div class=\"label\">[ABOUT]</div>\n        <h1 class=\"page-title\">The beauty<br>of <span class=\"accent-italic\">imperfection</span></h1>\n        <div class=\"bio-text mt-2 text-muted\">\n          <p>I'm a multimedia designer specializing in graphic design and video production. My work is deeply influenced by industrial and brutalist aesthetics — raw materials, exposed structures, and unpolished surfaces.</p>\n          <p>Equally important to my practice is the Japanese concept of wabi-sabi: the acceptance of transience and imperfection. I believe the most compelling design work comes from embracing what's incomplete, finding character in the worn, and creating meaning through restraint.</p>\n          <p>Every project is an opportunity to strip away the unnecessary and reveal something honest underneath.</p>\n        </div>\n      </div>\n      <div class=\"split-visuals\">\n         <div class=\"asset-box box-portrait grayscale-reveal reveal-img\">\n             <img src=\"asset://nqnqidh7b\" alt=\"Amiel Navigar\" class=\"asset-media parallax-img\" referrerPolicy=\"no-referrer\">\n             <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n             <div class=\"crosshair\"></div>\n             <div class=\"project-hover\">\n               <h3 class=\"project-title\">Amiel Navigar</h3>\n               <span class=\"project-year\">Designer 2025</span>\n            </div>\n         </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"experience fade-in-up mt-4\">\n    <div class=\"container\">\n      <div class=\"label\">[EXPERIENCE]</div>\n      <h2 class=\"section-title\">Background</h2>\n      \n      <div class=\"exp-list\">\n        <div class=\"exp-item exp-item-detailed\">\n          <div class=\"exp-header\">\n            <div class=\"exp-role\">Multimedia Designer <span class=\"text-muted\">— Xillium</span></div>\n            <div class=\"exp-date label\">2023 — Present</div>\n          </div>\n          <div class=\"exp-details text-muted text-sm mt-1\">\n            <p class=\"mb-1\"><em>Hybrid Setup</em></p>\n            <ul class=\"bullet-list\">\n              <li>Develop creative digital content for healthcare outsourcing clients, ensuring brand consistency across platforms.</li>\n              <li>Design marketing collaterals, social media graphics, and internal communication materials.</li>\n              <li>Collaborate with cross-functional teams to deliver effective design solutions within deadlines.</li>\n              <li>Produced professional layouts that strengthened visual branding.</li>\n            </ul>\n          </div>\n        </div>\n        <div class=\"exp-item exp-item-detailed\">\n          <div class=\"exp-header\">\n            <div class=\"exp-role\">Graphic Support Intern <span class=\"text-muted\">— ADA Asia</span></div>\n            <div class=\"exp-date label\">2023</div>\n          </div>\n          <div class=\"exp-details text-muted text-sm mt-1\">\n            <p class=\"mb-1\"><em>Office Based</em></p>\n            <ul class=\"bullet-list\">\n              <li>Created and delivered branded content for digital campaigns.</li>\n              <li>Handled the end-to-end development of creative projects from ideation to execution.</li>\n              <li>Designed online and offline collaterals for marketing initiatives.</li>\n              <li>Translated concepts and moods into impactful creative outputs.</li>\n            </ul>\n          </div>\n        </div>\n        <div class=\"exp-item exp-item-detailed\">\n          <div class=\"exp-header\">\n            <div class=\"exp-role\">Freelance Artist <span class=\"text-muted\">— Upwork</span></div>\n            <div class=\"exp-date label\">2022 — Present</div>\n          </div>\n          <div class=\"exp-details text-muted text-sm mt-1\">\n            <ul class=\"bullet-list\">\n              <li>Designed logos, brand identities, marketing collateral, illustrations, and more for international clients.</li>\n              <li>Specialized in visually captivating designs that communicate key messages effectively.</li>\n              <li>Maintained consistent collaboration with clients to ensure brand alignment.</li>\n            </ul>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"skills fade-in-up mt-4 mb-4\">\n    <div class=\"container\">\n      <div class=\"label\">[TOOLS & SKILLS]</div>\n      <h2 class=\"section-title\">Software & Qualifications</h2>\n      \n      <div class=\"tags-container mt-2\">\n        <span class=\"tag\">ADOBE CREATIVE SUITE</span>\n        <span class=\"tag\">PHOTOSHOP</span>\n        <span class=\"tag\">ILLUSTRATOR</span>\n        <span class=\"tag\">AFTER EFFECTS</span>\n        <span class=\"tag\">PREMIERE PRO</span>\n        <span class=\"tag\">AI-READY</span>\n        <span class=\"tag\">TEAM COLLABORATION</span>\n        <span class=\"tag\">INDEPENDENT WORK</span>\n        <span class=\"tag\">DETAIL-ORIENTED</span>\n        <span class=\"tag\">COMMUNICATION</span>\n      </div>\n\n      <div class=\"grid-3 mt-4\">\n        <div class=\"info-card\">\n          <h3 class=\"card-title\">Wabi-Sabi</h3>\n          <p class=\"text-muted text-sm\">Finding beauty in imperfection, impermanence, and incompleteness. Every crack tells a story.</p>\n        </div>\n        <div class=\"info-card\">\n          <h3 class=\"card-title\">Brutalism</h3>\n          <p class=\"text-muted text-sm\">Honesty in materials. Raw, unadorned, functional. Structure exposed, intention clear.</p>\n        </div>\n        <div class=\"info-card\">\n          <h3 class=\"card-title\">Industrial</h3>\n          <p class=\"text-muted text-sm\">The poetry of production. Machinery, texture, repetition. Where function becomes form.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n</main>\n\n<footer class=\"site-footer\">\n  <div class=\"container\">\n    <div class=\"footer-grid\">\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">MULTIMEDIA DESIGNER</h4>\n        <p class=\"text-muted\">Embracing imperfection.<br>Finding beauty in the raw.</p>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">NAVIGATION</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"index.html\">Home</a></li>\n          <li><a href=\"work.html\">Work</a></li>\n          <li><a href=\"about.html\">About</a></li>\n          <li><a href=\"contact.html\">Contact</a></li>\n        </ul>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">CONNECT</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"https://www.linkedin.com/in/amielnavigar/\" target=\"_blank\" rel=\"noopener noreferrer\">LinkedIn</a></li>\n        </ul>\n      </div>\n    </div>\n    <div class=\"footer-bottom\">\n      <div class=\"copyright\">© 2026</div>\n      <div class=\"quote\">Nothing is permanent.</div>\n    </div>\n  </div>\n</footer>\n\n<div id=\"custom-cursor\" class=\"custom-cursor\"></div>\n<script src=\"script.js\"></script>"},{"name":"contact.html","html":"<title>Contact - Amiel Navigar | Multimedia Designer</title>\n<link rel=\"stylesheet\" href=\"style.css\">\n<div class=\"page-transition\"></div>\n<header id=\"main-header\">\n  <div class=\"container header-inner\">\n    <a href=\"index.html\" class=\"logo\">AMIEL NAVIGAR</a>\n    <nav>\n      <ul class=\"nav-links\">\n        <li><a href=\"index.html\">HOME</a></li>\n        <li><a href=\"work.html\">WORK</a></li>\n        <li><a href=\"about.html\">ABOUT</a></li>\n        <li><a href=\"contact.html\" class=\"active\">CONTACT</a></li>\n        <li>\n          <button id=\"theme-toggle\" class=\"theme-toggle\" aria-label=\"Toggle Theme\">\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"currentColor\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 2v20a10 10 0 1 0 0-20z\"/></svg>\n          </button>\n        </li>\n      </ul>\n    </nav>\n  </div>\n</header>\n\n<main class=\"page-contact\">\n  <section class=\"contact-section fade-in-up\">\n    <div class=\"container split-layout-contact\">\n      <div class=\"contact-info\">\n        <div class=\"label\">[CONTACT]</div>\n        <h1 class=\"page-title\">Let's build<br>something <span class=\"accent-italic\">raw.</span></h1>\n        <p class=\"mt-2 text-muted max-w-sm\">\n          Open for freelance projects, collaborations, and creative partnerships. Let's create work that embraces imperfection.\n        </p>\n\n        <div class=\"contact-details mt-3\">\n          <div class=\"contact-item\">\n            <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--accent-color)\" stroke-width=\"1.5\"><rect x=\"2\" y=\"4\" width=\"20\" height=\"16\" rx=\"2\"/><path d=\"m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7\"/></svg>\n            <span class=\"label mono-text\">amielnavigar@gmail.com</span>\n          </div>\n          <div class=\"contact-item mt-1\">\n            <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--accent-color)\" stroke-width=\"1.5\"><path d=\"M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z\"/><circle cx=\"12\" cy=\"10\" r=\"3\"/></svg>\n            <span class=\"label mono-text\">Iloilo, Philippines</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"contact-form-wrapper\">\n        <form action=\"https://formsubmit.co/ajax/amielnavigar@gmail.com\" method=\"POST\" class=\"contact-form\" id=\"contact-form\">\n          <input type=\"hidden\" name=\"_template\" value=\"box\">\n          <input type=\"hidden\" name=\"_next\" value=\"https://lowkeycrystal.github.io/Amiel_Navigar_Portfolio/index.html\">\n          <input type=\"hidden\" name=\"_captcha\" value=\"false\">\n          <div class=\"form-group\">\n            <label class=\"label\" for=\"name\">NAME</label>\n            <input type=\"text\" name=\"name\" id=\"name\" placeholder=\"Your name\" required>\n          </div>\n          <div class=\"form-group\">\n            <label class=\"label\" for=\"email\">EMAIL</label>\n            <input type=\"email\" name=\"email\" id=\"email\" placeholder=\"your@email.com\" required>\n          </div>\n          <div class=\"form-group\">\n            <label class=\"label\" for=\"type\">PROJECT TYPE</label>\n            <input type=\"text\" name=\"_subject\" id=\"type\" placeholder=\"Graphic / Video / Motion / Other\">\n          </div>\n          <div class=\"form-group\">\n            <label class=\"label\" for=\"message\">MESSAGE</label>\n            <textarea name=\"message\" id=\"message\" rows=\"4\" placeholder=\"Tell me about your project...\" required></textarea>\n          </div>\n          <button type=\"submit\" class=\"btn-outline mt-2\">SEND MESSAGE <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M5 12h14M12 5l7 7-7\"/></svg></button>\n          <div id=\"form-messages\" class=\"label mt-2\" style=\"text-transform: none; letter-spacing: normal;\"></div>\n        </form>\n      </div>\n    </div>\n  </section>\n</main>\n\n<footer class=\"site-footer\">\n  <div class=\"container\">\n    <div class=\"footer-grid\">\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">MULTIMEDIA DESIGNER</h4>\n        <p class=\"text-muted\">Embracing imperfection.<br>Finding beauty in the raw.</p>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">NAVIGATION</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"index.html\">Home</a></li>\n          <li><a href=\"work.html\">Work</a></li>\n          <li><a href=\"about.html\">About</a></li>\n          <li><a href=\"contact.html\">Contact</a></li>\n        </ul>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">CONNECT</h4>\n        <ul class=\"footer-links\">\n          <li><a href=\"https://www.linkedin.com/in/amielnavigar/\" target=\"_blank\" rel=\"noopener noreferrer\">LinkedIn</a></li>\n        </ul>\n      </div>\n    </div>\n    <div class=\"footer-bottom\">\n      <div class=\"copyright\">© 2026</div>\n      <div class=\"quote\">Nothing is permanent.</div>\n    </div>\n  </div>\n</footer>\n\n<div id=\"custom-cursor\" class=\"custom-cursor\"></div>\n<script src=\"script.js\"></script>"},{"name":"index.html","html":"<title>Amiel Navigar | Portfolio</title>\n<link rel=\"stylesheet\" href=\"style.css\">\n<div class=\"page-transition\"></div>\n<header id=\"main-header\">\n  <div class=\"container header-inner\">\n    <a href=\"index.html\" class=\"logo\">AMIEL NAVIGAR</a>\n    <nav>\n      <ul class=\"nav-links\">\n        <li><a href=\"index.html\" class=\"active\" aria-current=\"page\">HOME</a></li>\n        <li><a href=\"work.html\">WORK</a></li>\n        <li><a href=\"about.html\">ABOUT</a></li>\n        <li><a href=\"contact.html\">CONTACT</a></li>\n        <li>\n          <button id=\"theme-toggle\" class=\"theme-toggle\" aria-label=\"Toggle Theme\">\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"currentColor\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 2v20a10 10 0 1 0 0-20z\"/></svg>\n          </button>\n        </li>\n      </ul>\n    </nav>\n  </div>\n</header>\n\n<main>\n  <section class=\"hero slide-up-group\">\n    <div class=\"container relative\">\n      <div class=\"label inline-flex items-center gap-2 flex-wrap\"><span class=\"pulsing-dot\"></span> [MULTIMEDIA DESIGNER] [AI-ASSISTED] [AI-READY]</div>\n      <h1 class=\"hero-title display-xl\">\n        <span class=\"block overflow-hidden\"><span class=\"reveal-text\">Crafting</span></span>\n        <span class=\"block overflow-hidden\"><span class=\"reveal-text\">the <span class=\"accent-outline\">Authentic</span></span></span>\n      </h1>\n      <div class=\"hero-sub mt-3 flex-row-responsive\">\n        <div class=\"fade-in-up stagger-1 max-w-md\">\n          <p class=\"mb-1\" style=\"color: var(--text-primary); font-weight: 600; white-space: nowrap; font-size: clamp(0.65rem, 2.5vw, 1.15rem);\">\n            Driven by intentions. Crafted with purpose. Eliminating the unnecessary.\n          </p>\n          <p class=\"text-lg text-muted\">\n            Graphic design & video work rooted in brutalist aesthetics and wabi-sabi philosophy. Embracing rawness, asymmetry, and honest form.\n          </p>\n        </div>\n        <div class=\"fade-in-up stagger-2\">\n          <a href=\"work.html\" class=\"circle-btn\">\n            <span class=\"circle-btn-text\">VIEW<br>WORK</span>\n            <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M5 12h14M12 5l7 7-7\"/></svg>\n          </a>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <div class=\"marquee py-2 border-y my-2\">\n    <div class=\"marquee-content\">\n      <span class=\"marquee-text\">NOTHING IS PERMANENT • CRAFTING THE AUTHENTIC • EMBRACING RAWNESS • FINDING BEAUTY IN SIMPLICITY • </span>\n      <span class=\"marquee-text\">NOTHING IS PERMANENT • CRAFTING THE AUTHENTIC • EMBRACING RAWNESS • FINDING BEAUTY IN SIMPLICITY • </span>\n    </div>\n  </div>\n\n  <section class=\"about-snippet fade-in-up mt-4\">\n    <div class=\"container split-layout align-center\">\n      <div class=\"split-visuals relative\">\n        <div class=\"asset-box box-square\">\n           <video autoplay loop muted playsinline class=\"asset-media parallax-img\">\n             <source src=\"asset://ds1v2otmm\" type=\"video/mp4\">\n           </video>\n           <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n           <div class=\"crosshair\"></div>\n        </div>\n      </div>\n      <div class=\"split-text\">\n        <div class=\"label\">[ABOUT ME]</div>\n        <h2 class=\"large-heading mb-2\">Design that feels <span class=\"accent-italic\">alive.</span></h2>\n        <p class=\"text-muted text-lg mb-3\">\n          I build digital experiences and visual identities that don't hide their structure. Let's strip away the unnecessary polish and reveal the honest core of your brand.\n        </p>\n        <a href=\"about.html\" class=\"btn-outline\">\n          READ MY STORY <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M5 12h14M12 5l7 7-7\"/></svg>\n        </a>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"recent-projects mt-4\">\n    <div class=\"container\">\n      <div class=\"flex justify-between items-end mb-3 fade-in-up\">\n        <div>\n          <div class=\"label\">[SELECTED WORK]</div>\n          <h2 class=\"section-title mb-0\">Recent Projects</h2>\n        </div>\n        <a href=\"work.html\" class=\"link-btn hidden-mobile\">ALL PROJECTS <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M5 12h14M12 5l7 7-7\"/></svg></a>\n      </div>\n      \n      <div class=\"bento-grid fade-in-up\">\n        <a href=\"project-becker.html\" class=\"asset-box span-3 box-square grayscale-reveal reveal-img\" data-category=\"graphic\">\n           <img src=\"asset://1774738706550\" alt=\"Becker's Event Announcement\" class=\"asset-media parallax-img\" referrerPolicy=\"no-referrer\" loading=\"lazy\">\n           <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n           <div class=\"crosshair\"></div>\n           <div class=\"project-hover\">\n             <h3 class=\"project-title\">Becker's Event</h3>\n             <span class=\"project-year\">Graphic 2026</span>\n          </div>\n        </a>\n        <a href=\"project-tj-bt21.html\" class=\"asset-box span-3 box-square grayscale-reveal reveal-img\" data-category=\"animation\">\n          <video autoplay loop muted playsinline class=\"asset-media parallax-img\">\n            <source src=\"asset://elip7b2ii\" type=\"video/mp4\">\n          </video>\n          <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n          <div class=\"crosshair\"></div>\n          <div class=\"project-hover\">\n             <h3 class=\"project-title\">Tender Juicy BT21</h3>\n             <span class=\"project-year\">Animation 2023</span>\n          </div>\n        </a>\n        <a href=\"project-mgma.html\" class=\"asset-box span-3 box-square grayscale-reveal reveal-img\" data-category=\"video\">\n           <video autoplay loop muted playsinline class=\"asset-media parallax-img\">\n             <source src=\"asset://1774738684886\" type=\"video/mp4\">\n           </video>\n           <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n           <div class=\"crosshair\"></div>\n           <div class=\"project-hover\">\n             <h3 class=\"project-title\">MGMA Wrap Up</h3>\n             <span class=\"project-year\">Video 2025</span>\n          </div>\n        </a>\n        <a href=\"project-samsung.html\" class=\"asset-box span-3 box-square grayscale-reveal reveal-img\" data-category=\"graphic\">\n           <img src=\"asset://o6s4kgm2s\" alt=\"Samsung Product Ad\" class=\"asset-media parallax-img\" referrerPolicy=\"no-referrer\" loading=\"lazy\">\n           <div class=\"corner corner-tl\"></div><div class=\"corner corner-tr\"></div><div class=\"corner corner-bl\"></div><div class=\"corner corner-br\"></div>\n           <div class=\"crosshair\"></div>\n           <div class=\"project-hover\">\n             <h3 class=\"project-title\">Samsung Product Ad</h3>\n             <span class=\"project-year\">Graphic 2023</span>\n          </div>\n        </a>\n      </div>\n      <div class=\"text-center mt-3 hidden-desktop fade-in-up\">\n         <a href=\"work.html\" class=\"btn-outline w-full justify-center\">ALL PROJECTS <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M5 12h14M12 5l7 7-7\"/></svg></a>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"capabilities mt-4 fade-in-up border-t\">\n    <div class=\"container\">\n       <div class=\"flex justify-between items-start mb-3\">\n         <div class=\"label\">[CAPABILITIES]</div>\n         <h2 class=\"section-title mb-0 max-w-sm text-right\">What I Do</h2>\n       </div>\n       <div class=\"interactive-list\">\n         <div class=\"list-item hover-trigger\">\n           <div class=\"list-num label\">01</div>\n           <h3 class=\"list-title text-huge\">Graphic Design</h3>\n           <p class=\"list-desc text-muted hidden-mobile\">Brand identities, posters, editorial, packaging</p>\n           <div class=\"list-arrow\">\n             <svg width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--accent-color)\" stroke-width=\"1.5\"><path d=\"M5 12h14M12 5l7 7-7\"/></svg>\n           </div>\n         </div>\n         <div class=\"list-item hover-trigger\">\n           <div class=\"list-num label\">02</div>\n           <h3 class=\"list-title text-huge\">Motion Design</h3>\n           <p class=\"list-desc text-muted hidden-mobile\">Animations, title sequences, motion graphics</p>\n           <div class=\"list-arrow\">\n             <svg width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--accent-color)\" stroke-width=\"1.5\"><path d=\"M5 12h14M12 5l7 7-7\"/></svg>\n           </div>\n         </div>\n         <div class=\"list-item hover-trigger\">\n           <div class=\"list-num label\">03</div>\n           <h3 class=\"list-title text-huge\">Video Production</h3>\n           <p class=\"list-desc text-muted hidden-mobile\">Short films, campaigns, visual essays</p>\n           <div class=\"list-arrow\">\n             <svg width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--accent-color)\" stroke-width=\"1.5\"><path d=\"M5 12h14M12 5l7 7-7\"/></svg>\n           </div>\n         </div>\n         <div class=\"list-item hover-trigger border-b-0\">\n           <div class=\"list-num label\">04</div>\n           <h3 class=\"list-title text-huge\">Art Direction</h3>\n           <p class=\"list-desc text-muted hidden-mobile\">Visual strategy, creative direction, concepts</p>\n           <div class=\"list-arrow\">\n             <svg width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"